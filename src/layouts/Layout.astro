---
import Sidebar from '../components/Sidebar.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';

// Self-host typography locally to prevent render blocking and layout shift
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';
import '@fontsource/fira-code/400.css';
import '@fontsource/fira-code/500.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  activeTool?: string;
  accentColor?: string;
  accentGlow?: string;
}

const { 
  title, 
  description, 
  keywords = "developer tools, json formatter, base64 encoder, regex tester, url encoder, jwt decoder, online tools", 
  activeTool = "",
  accentColor = "#6366f1",
  accentGlow = "rgba(99, 102, 241, 0.15)"
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site || "https://instanttoolshub.com");
const fullTitle = title ? `${title} | InstantToolsHub` : "InstantToolsHub — Free Online Developer Tools";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0G0S0R595C" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0G0S0R595C');
    </script>

    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="InstantToolsHub" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl.href} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://instanttoolshub.com/og-image.jpg" />
    <meta property="og:site_name" content="InstantToolsHub" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl.href} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://instanttoolshub.com/og-image.jpg" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#080c14" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <meta name="generator" content={Astro.generator} />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "InstantToolsHub",
        "url": "https://instanttoolshub.com",
        "description": "Free, secure, client-side developer tools for formatting, encoding, decoding, and debugging.",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://instanttoolshub.com/?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "InstantToolsHub Developer Suite",
        "operatingSystem": "All",
        "applicationCategory": "DeveloperApplication",
        "offers": {
          "@type": "Offer",
          "price": "0.00",
          "priceCurrency": "USD"
        }
      }
    </script>

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "InstantToolsHub",
        "url": "https://instanttoolshub.com",
        "logo": "https://instanttoolshub.com/favicon.svg"
      }
    </script>

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://instanttoolshub.com/"
        },
        ...(activeTool ? [{
          "@type": "ListItem",
          "position": 2,
          "name": title,
          "item": canonicalUrl.href
        }] : [])
      ]
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <div 
      class="layout-wrapper" 
      id="app-layout"
      style={`--accent-primary: ${accentColor}; --accent-glow: ${accentGlow}; --accent-hover: ${accentColor}dd;`}
    >
      <div id="mobile-sidebar-backdrop" class="sidebar-backdrop"></div>
      <div id="sidebar-container" class="sidebar-container">
        <Sidebar activeTool={activeTool} />
      </div>
      <div class="content-container">
        <Header />
        <main id="main-content"><slot /></main>
        <div class="ad-container" id="ad-footer-unit" aria-hidden="true"></div>

        <footer class="app-footer">
          <div class="footer-content">
            <div class="footer-left">
              <span class="footer-logo">Instant<span>ToolsHub</span></span>
              <p class="footer-desc">Free, secure, client-side tools for developers.</p>
            </div>
            <nav class="footer-tools" aria-label="Tools navigation">
              <h3 class="footer-group-label">Tools</h3>
              <ul class="footer-tools-list">
                <li><a href="/json-formatter">JSON Formatter</a></li>
                <li><a href="/base64">Base64</a></li>
                <li><a href="/url-encoder-decoder">URL Encoder/Decoder</a></li>
                <li><a href="/regex-tester">RegEx Tester</a></li>
                <li><a href="/jwt-decoder">JWT Decoder</a></li>
                <li><a href="/code-minifier-beautifier">Code Minifier</a></li>
                <li><a href="/markdown-editor">Markdown Editor</a></li>
                <li><a href="/color-converter">Color Converter</a></li>
                <li><a href="/timestamp">Timestamp Converter</a></li>
                <li><a href="/hash-generator">Hash Generator</a></li>
              </ul>
            </nav>
            <nav class="footer-links" aria-label="Footer navigation">
              <a href="/">Home</a>
              <a href="/blog">Blog</a>
              <a href="https://github.com/shakumar5" target="_blank" rel="noopener noreferrer">GitHub</a>
            </nav>
            <div class="footer-right">
              <p>&copy; {new Date().getFullYear()} InstantToolsHub. All code is processed locally in your browser.</p>
            </div>
          </div>
        </footer>
      </div>
    </div>
    <style>
      .skip-to-content {
        position: absolute;
        top: -100%;
        left: 1rem;
        z-index: 9999;
        padding: 0.75rem 1.5rem;
        background: var(--accent-primary);
        color: #fff;
        border-radius: var(--radius-sm);
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: top 0.2s ease;
      }

      .skip-to-content:focus {
        top: 1rem;
      }

      .layout-wrapper {
        display: grid;
        grid-template-columns: var(--sidebar-width) 1fr;
        grid-template-areas: "sidebar main-content";
        min-height: 100vh;
        width: 100vw;
      }

      .sidebar-container {
        grid-area: sidebar;
        width: var(--sidebar-width);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        height: 100vh;
        z-index: 99;
      }

      .content-container {
        grid-area: main-content;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overflow-x: hidden;
      }

      main {
        flex-grow: 1;
        padding: 2rem;
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .sidebar-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        z-index: 90;
      }

      /* Ad Container - fixed dimensions for zero CLS contribution */
      .ad-container {
        height: 90px;
        width: 100%;
        max-width: 728px;
        margin: 1rem auto;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* Footer styling */
      .app-footer {
        border-top: 1px solid var(--border-light);
        background: #06090f;
        padding: 2.5rem 2rem;
        margin-top: 2rem;
        color: var(--text-muted);
        font-size: 0.85rem;
      }

      .footer-content {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 2rem;
      }

      .footer-logo {
        font-family: var(--font-heading);
        font-size: 1.15rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 0.25rem;
        display: inline-block;
      }

      .footer-logo span {
        color: var(--accent-primary);
      }

      .footer-desc {
        font-size: 0.875rem;
      }

      .footer-tools {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .footer-group-label {
        font-family: var(--font-heading);
        font-size: 0.85rem;
        font-weight: 600;
        color: #fff;
        margin: 0 0 0.25rem 0;
      }

      .footer-tools-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.25rem;
        font-size: 0.875rem;
      }

      .footer-tools-list li a {
        color: var(--text-secondary);
        transition: color var(--transition-fast);
      }

      .footer-tools-list li a:hover {
        color: var(--accent-primary);
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.5rem;
        font-size: 0.875rem;
      }

      .footer-links a {
        color: var(--text-secondary);
        transition: color var(--transition-fast);
      }

      .footer-links a:hover {
        color: var(--accent-primary);
      }

      /* Responsive rules */
      @media (max-width: 768px) {
        .layout-wrapper {
          grid-template-columns: 1fr;
          grid-template-areas: "main-content";
        }

        .sidebar-container {
          transform: translateX(-100%);
          transition: transform var(--transition-normal);
        }

        .layout-wrapper.mobile-sidebar-open .sidebar-container {
          transform: translateX(0);
        }

        .layout-wrapper.mobile-sidebar-open .sidebar-backdrop {
          display: block;
        }

        .content-container {
          margin-left: 0;
        }

        main {
          padding: 1.25rem;
        }

        .footer-content {
          flex-direction: column;
          align-items: flex-start;
          text-align: left;
        }
      }
    </style>

    <script is:inline type="module">
      (function() {
        function loadAdSense() {
          var containers = document.querySelectorAll('.ad-container');
          if (!containers.length) return;

          var adScript = document.createElement('script');
          adScript.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js';
          adScript.async = true;
          adScript.crossOrigin = 'anonymous';

          var fillTimeout;

          function collapseAllContainers() {
            containers.forEach(function(container) {
              container.style.height = '0px';
              container.style.overflow = 'hidden';
              container.style.padding = '0';
              container.style.margin = '0';
              container.style.border = 'none';
              container.style.background = 'none';
              container.style.transition = 'none';
              var placeholder = container.querySelector('.ad-placeholder');
              if (placeholder) {
                placeholder.style.height = '0px';
                placeholder.style.overflow = 'hidden';
                placeholder.style.minHeight = '0';
                placeholder.style.border = 'none';
                placeholder.style.background = 'none';
                placeholder.style.transition = 'none';
              }
            });
          }

          adScript.onload = function() {
            // Initialize ad slots
            try {
              containers.forEach(function() {
                (window.adsbygoogle = window.adsbygoogle || []).push({});
              });
            } catch (e) {
              collapseAllContainers();
              return;
            }

            // Set 10-second timeout for no-fill detection
            fillTimeout = setTimeout(function() {
              containers.forEach(function(container) {
                var ins = container.querySelector('ins.adsbygoogle');
                // If no ins element or it has no content/data-ad-status is unfilled
                if (!ins || ins.getAttribute('data-ad-status') === 'unfilled' || ins.innerHTML.trim() === '') {
                  container.style.height = '0px';
                  container.style.overflow = 'hidden';
                  container.style.padding = '0';
                  container.style.margin = '0';
                  container.style.border = 'none';
                  container.style.background = 'none';
                  container.style.transition = 'none';
                  var placeholder = container.querySelector('.ad-placeholder');
                  if (placeholder) {
                    placeholder.style.height = '0px';
                    placeholder.style.overflow = 'hidden';
                    placeholder.style.minHeight = '0';
                    placeholder.style.border = 'none';
                    placeholder.style.background = 'none';
                    placeholder.style.transition = 'none';
                  }
                }
              });
            }, 10000);
          };

          adScript.onerror = function() {
            collapseAllContainers();
          };

          document.head.appendChild(adScript);
        }

        // Use requestIdleCallback with setTimeout 5s fallback
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadAdSense);
        } else {
          setTimeout(loadAdSense, 5000);
        }
      })();
    </script>
    <script>
      // Manage mobile sidebar drawer with focus management
      const menuToggle = document.getElementById('mobile-menu-toggle');
      const layoutWrapper = document.getElementById('app-layout');
      const backdrop = document.getElementById('mobile-sidebar-backdrop');
      const sidebarContainer = document.getElementById('sidebar-container');
      const sidebarCloseBtn = document.getElementById('sidebar-close-btn');

      function isMobileViewport(): boolean {
        return window.innerWidth < 768;
      }

      function getFocusableElements(): HTMLElement[] {
        if (!sidebarContainer) return [];
        const selectors = 'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])';
        return Array.from(sidebarContainer.querySelectorAll<HTMLElement>(selectors))
          .filter(el => {
            const style = window.getComputedStyle(el);
            return style.display !== 'none' && style.visibility !== 'hidden';
          });
      }

      function openSidebar() {
        if (!layoutWrapper || !sidebarContainer) return;
        layoutWrapper.classList.add('mobile-sidebar-open');

        if (isMobileViewport()) {
          // Set dialog role and aria-modal for mobile drawer
          sidebarContainer.setAttribute('role', 'dialog');
          sidebarContainer.setAttribute('aria-modal', 'true');
          sidebarContainer.setAttribute('aria-label', 'Navigation menu');

          // Move focus to close button after transition
          requestAnimationFrame(() => {
            if (sidebarCloseBtn) {
              sidebarCloseBtn.focus();
            }
          });
        }
      }

      function closeSidebar() {
        if (!layoutWrapper || !sidebarContainer) return;
        layoutWrapper.classList.remove('mobile-sidebar-open');

        if (isMobileViewport()) {
          // Remove dialog role attributes
          sidebarContainer.removeAttribute('role');
          sidebarContainer.removeAttribute('aria-modal');
          sidebarContainer.removeAttribute('aria-label');

          // Return focus to hamburger button
          if (menuToggle) {
            menuToggle.focus();
          }
        }
      }

      function toggleSidebar() {
        if (!layoutWrapper) return;
        if (layoutWrapper.classList.contains('mobile-sidebar-open')) {
          closeSidebar();
        } else {
          openSidebar();
        }
      }

      // Focus trap handler for Tab/Shift+Tab
      function handleFocusTrap(e: KeyboardEvent) {
        if (!isMobileViewport()) return;
        if (!layoutWrapper?.classList.contains('mobile-sidebar-open')) return;

        if (e.key === 'Tab') {
          const focusableEls = getFocusableElements();
          if (focusableEls.length === 0) return;

          const firstFocusable = focusableEls[0];
          const lastFocusable = focusableEls[focusableEls.length - 1];

          if (e.shiftKey) {
            // Shift+Tab: if on first element, wrap to last
            if (document.activeElement === firstFocusable) {
              e.preventDefault();
              lastFocusable.focus();
            }
          } else {
            // Tab: if on last element, wrap to first
            if (document.activeElement === lastFocusable) {
              e.preventDefault();
              firstFocusable.focus();
            }
          }
        }
      }

      // Escape key handler
      function handleEscapeKey(e: KeyboardEvent) {
        if (e.key === 'Escape' && isMobileViewport() && layoutWrapper?.classList.contains('mobile-sidebar-open')) {
          e.preventDefault();
          closeSidebar();
        }
      }

      // Event listeners
      if (menuToggle) {
        menuToggle.addEventListener('click', toggleSidebar);
      }

      if (sidebarCloseBtn) {
        sidebarCloseBtn.addEventListener('click', closeSidebar);
      }

      if (backdrop) {
        backdrop.addEventListener('click', closeSidebar);
      }

      document.addEventListener('keydown', handleEscapeKey);
      document.addEventListener('keydown', handleFocusTrap);

      // Clean up dialog attributes on resize to desktop
      window.addEventListener('resize', () => {
        if (!isMobileViewport() && sidebarContainer) {
          sidebarContainer.removeAttribute('role');
          sidebarContainer.removeAttribute('aria-modal');
          sidebarContainer.removeAttribute('aria-label');
        }
      });

      // Register Service Worker for PWA offline support
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});

        // Listen for service worker updates and show toast notification
        navigator.serviceWorker.addEventListener('controllerchange', () => {
          // Avoid showing multiple toasts
          if (document.getElementById('sw-update-toast')) return;

          const toast = document.createElement('div');
          toast.id = 'sw-update-toast';
          toast.setAttribute('role', 'status');
          toast.setAttribute('aria-live', 'polite');
          toast.innerHTML = `
            <span class="sw-toast-message">App updated! Refresh for the latest version.</span>
            <button class="sw-toast-dismiss" aria-label="Dismiss notification">&times;</button>
          `;

          // Apply inline styles for the toast
          Object.assign(toast.style, {
            position: 'fixed',
            bottom: '1.5rem',
            left: '50%',
            transform: 'translateX(-50%)',
            background: '#1e293b',
            color: '#f8fafc',
            padding: '0.875rem 1.25rem',
            borderRadius: '0.5rem',
            display: 'flex',
            alignItems: 'center',
            gap: '1rem',
            boxShadow: '0 4px 24px rgba(0, 0, 0, 0.4)',
            zIndex: '10000',
            fontSize: '0.9rem',
            fontFamily: 'var(--font-body, system-ui, sans-serif)',
            maxWidth: '90vw',
            animation: 'sw-toast-in 0.3s ease-out'
          });

          // Style the dismiss button
          const dismissBtn = toast.querySelector('.sw-toast-dismiss') as HTMLButtonElement | null;
          if (dismissBtn) {
            Object.assign(dismissBtn.style, {
              background: 'transparent',
              border: 'none',
              color: '#94a3b8',
              fontSize: '1.25rem',
              cursor: 'pointer',
              padding: '0.25rem 0.5rem',
              lineHeight: '1',
              borderRadius: '0.25rem',
              transition: 'color 0.2s'
            });
            dismissBtn.addEventListener('mouseenter', () => {
              dismissBtn.style.color = '#f8fafc';
            });
            dismissBtn.addEventListener('mouseleave', () => {
              dismissBtn.style.color = '#94a3b8';
            });
          }

          // Add animation keyframes
          const styleEl = document.createElement('style');
          styleEl.textContent = `
            @keyframes sw-toast-in {
              from { opacity: 0; transform: translateX(-50%) translateY(1rem); }
              to { opacity: 1; transform: translateX(-50%) translateY(0); }
            }
            @keyframes sw-toast-out {
              from { opacity: 1; transform: translateX(-50%) translateY(0); }
              to { opacity: 0; transform: translateX(-50%) translateY(1rem); }
            }
          `;
          document.head.appendChild(styleEl);

          function dismissToast() {
            toast.style.animation = 'sw-toast-out 0.3s ease-in forwards';
            toast.addEventListener('animationend', () => {
              toast.remove();
              styleEl.remove();
            }, { once: true });
          }

          // Dismiss on button click
          if (dismissBtn) {
            dismissBtn.addEventListener('click', dismissToast);
          }

          // Auto-dismiss after 8 seconds
          setTimeout(dismissToast, 8000);

          document.body.appendChild(toast);
        });
      }
    </script>
  </body>
</html>
