---
import Sidebar from '../components/Sidebar.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';

import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';
import '@fontsource/fira-code/400.css';
import '@fontsource/fira-code/500.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  publishDate?: string;
  dateModified?: string;
  author?: string;
  category?: string;
}

const { 
  title, 
  description, 
  keywords = "developer blog, web development, programming tutorials",
  publishDate = "",
  dateModified = "",
  author = "ToolsHub Team",
  category = "Development"
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site || "https://instanttoolshub.com");
const fullTitle = `${title} | ToolsHub Blog`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0G0S0R595C" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0G0S0R595C');
    </script>

    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl.href} />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://instanttoolshub.com/og-image.jpg" />
    <meta property="og:site_name" content="ToolsHub" />
    <meta property="article:published_time" content={publishDate} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#080c14" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "author": { "@type": "Person", "name": author },
      "publisher": { "@type": "Organization", "name": "ToolsHub", "logo": { "@type": "ImageObject", "url": "https://instanttoolshub.com/favicon.svg" } },
      "datePublished": publishDate,
      "dateModified": dateModified || publishDate,
      "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl.href }
    })} />
  </head>
  <body>
    <div 
      class="layout-wrapper" 
      id="app-layout"
      style="--accent-primary: #6366f1; --accent-glow: rgba(99, 102, 241, 0.15); --accent-hover: #6366f1dd;"
    >
      <div id="mobile-sidebar-backdrop" class="sidebar-backdrop"></div>
      
      <div id="sidebar-container" class="sidebar-container">
        <Sidebar />
      </div>

      <div class="content-container">
        <Header />
        <main>
          <article class="blog-article">
            <div class="blog-meta">
              <span class="blog-category">{category}</span>
              {publishDate && <time class="blog-date">{publishDate}</time>}
              <span class="blog-author">By {author}</span>
            </div>
            <slot />
          </article>
        </main>

        <footer class="app-footer">
          <div class="footer-content">
            <div class="footer-left">
              <span class="footer-logo">Tools<span>Hub</span></span>
              <p class="footer-desc">Free, secure, client-side tools for developers.</p>
            </div>
            <nav class="footer-links" aria-label="Footer navigation">
              <a href="/">Home</a>
              <a href="/blog">Blog</a>
              <a href="/json-formatter">JSON Formatter</a>
              <a href="/base64">Base64</a>
              <a href="/regex-tester">RegEx Tester</a>
              <a href="/jwt-decoder">JWT Decoder</a>
            </nav>
            <div class="footer-right">
              <p>&copy; {new Date().getFullYear()} ToolsHub. All code is processed locally in your browser.</p>
            </div>
          </div>
        </footer>
      </div>
    </div>

    <style>
      .layout-wrapper {
        display: grid;
        grid-template-columns: var(--sidebar-width) 1fr;
        grid-template-areas: "sidebar main-content";
        min-height: 100vh;
        width: 100vw;
      }

      .sidebar-container {
        grid-area: sidebar;
        width: var(--sidebar-width);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        height: 100vh;
        z-index: 99;
      }

      .content-container {
        grid-area: main-content;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overflow-x: hidden;
      }

      main {
        flex-grow: 1;
        padding: 2rem 3rem;
        width: 100%;
        max-width: 920px;
        margin: 0 auto;
      }

      .sidebar-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        z-index: 90;
      }

      .blog-article {
        color: #cbd5e1;
        line-height: 1.75;
        font-size: 1rem;
      }

      .blog-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-light);
        flex-wrap: wrap;
      }

      .blog-category {
        background: var(--accent-primary);
        color: #fff;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .blog-date, .blog-author {
        font-size: 0.85rem;
        color: var(--text-muted);
      }

      :global(.blog-article h1) {
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1rem;
        line-height: 1.2;
      }

      :global(.blog-article h2) {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border-light);
        padding-bottom: 0.5rem;
      }

      :global(.blog-article h3) {
        font-size: 1.2rem;
        font-weight: 600;
        color: #e2e8f0;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }

      :global(.blog-article p) {
        margin-bottom: 1.25rem;
        color: #cbd5e1;
      }

      :global(.blog-article code) {
        font-family: var(--font-mono);
        background: rgba(255, 255, 255, 0.08);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        color: #a78bfa;
        font-size: 0.9rem;
      }

      :global(.blog-article pre) {
        background: #000;
        padding: 1.25rem;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border-light);
        overflow-x: auto;
        margin-bottom: 1.5rem;
      }

      :global(.blog-article pre code) {
        color: #f3f4f6;
        background: transparent;
        padding: 0;
      }

      :global(.blog-article ul, .blog-article ol) {
        margin-left: 1.5rem;
        margin-bottom: 1.25rem;
      }

      :global(.blog-article li) {
        margin-bottom: 0.5rem;
      }

      :global(.blog-article blockquote) {
        border-left: 4px solid var(--accent-primary);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: var(--text-secondary);
        font-style: italic;
      }

      :global(.blog-article table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
      }

      :global(.blog-article th, .blog-article td) {
        border: 1px solid var(--border-light);
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
      }

      :global(.blog-article th) {
        background: rgba(255, 255, 255, 0.03);
        font-weight: 600;
        color: #fff;
      }

      :global(.blog-article a) {
        color: var(--accent-primary);
        text-decoration: underline;
      }

      :global(.blog-article .cta-box) {
        background: rgba(99, 102, 241, 0.08);
        border: 1px solid rgba(99, 102, 241, 0.3);
        border-radius: var(--radius-sm);
        padding: 1.25rem 1.5rem;
        margin: 2rem 0;
      }

      :global(.blog-article .cta-box a) {
        font-weight: 600;
      }

      .app-footer {
        border-top: 1px solid var(--border-light);
        background: #06090f;
        padding: 2.5rem 2rem;
        margin-top: 2rem;
        color: var(--text-muted);
        font-size: 0.85rem;
      }

      .footer-content {
        max-width: 820px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 2rem;
      }

      .footer-logo {
        font-family: var(--font-heading);
        font-size: 1.15rem;
        font-weight: 800;
        color: #fff;
      }

      .footer-logo span { color: var(--accent-primary); }
      .footer-desc { font-size: 0.8rem; }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.5rem;
        font-size: 0.8rem;
      }

      .footer-links a { color: var(--text-secondary); }
      .footer-links a:hover { color: var(--accent-primary); }

      @media (max-width: 768px) {
        .layout-wrapper {
          grid-template-columns: 1fr;
          grid-template-areas: "main-content";
        }
        .sidebar-container { transform: translateX(-100%); transition: transform var(--transition-normal); }
        .layout-wrapper.mobile-sidebar-open .sidebar-container { transform: translateX(0); }
        .layout-wrapper.mobile-sidebar-open .sidebar-backdrop { display: block; }
        main { padding: 1.25rem; }
        .footer-content { flex-direction: column; }
      }
    </style>

    <script>
      const menuToggle = document.getElementById('mobile-menu-toggle');
      const layoutWrapper = document.getElementById('app-layout');
      const backdrop = document.getElementById('mobile-sidebar-backdrop');

      function toggleSidebar() { layoutWrapper?.classList.toggle('mobile-sidebar-open'); }
      function closeSidebar() { layoutWrapper?.classList.remove('mobile-sidebar-open'); }

      menuToggle?.addEventListener('click', toggleSidebar);
      backdrop?.addEventListener('click', closeSidebar);
    </script>
  </body>
</html>
