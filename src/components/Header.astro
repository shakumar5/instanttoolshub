---
---

<header class="top-header">
  <div class="mobile-logo-area">
    <button id="mobile-menu-toggle" aria-label="Toggle menu" class="mobile-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
    </button>
    <a href="/" class="mobile-logo">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="color: var(--accent-primary);"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>
      <span>Instant<span>ToolsHub</span></span>
    </a>
  </div>

  <div class="header-right">
    <a href="/about" class="github-link" aria-label="About InstantToolsHub">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
    </a>
  </div>
</header>

<style>
  .top-header {
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    border-bottom: 1px solid var(--border-light);
    background: rgba(8, 12, 20, 0.85);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
  }

  .mobile-logo-area {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .mobile-btn {
    display: none;
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .mobile-btn:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  .mobile-logo {
    display: none;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    text-decoration: none;
  }

  .mobile-logo span span {
    color: var(--accent-primary);
  }

  .github-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
    padding: 0.5rem;
    border-radius: var(--radius-sm);
  }

  .github-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  @media (max-width: 768px) {
    .mobile-btn, .mobile-logo {
      display: flex;
    }
  }
</style>
