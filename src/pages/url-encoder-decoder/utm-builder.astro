---
import Layout from '../../layouts/Layout.astro';
import SEOContent from '../../components/SEOContent.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const toolName = "UTM Campaign URL Builder Online — Free, Instant, Private";
const pageHeading = "UTM Campaign URL Builder";
const activeTool = "url-encoder-decoder";
const accentColor = "#3b82f6";
const accentGlow = "rgba(59, 130, 246, 0.15)";

const seoDescription = "Build UTM campaign tracking URLs for Google Analytics instantly. Add utm_source, utm_medium, utm_campaign, utm_term, and utm_content parameters — 100% free, client-side.";
const seoKeywords = "utm builder, utm campaign builder, utm url generator, google analytics utm, utm parameters, campaign url builder, utm link builder free, utm tag generator";

const howToUse = [
  "Enter your website URL (the page you want to link to).",
  "Fill in the required Campaign Source (e.g. google, newsletter, twitter).",
  "Fill in Campaign Medium (e.g. cpc, email, social).",
  "Enter the Campaign Name (e.g. summer_sale, product_launch).",
  "Optionally add Campaign Term (paid keywords) and Campaign Content (for A/B testing).",
  "The generated UTM URL updates in real time as you type.",
  "Click 'Copy' to copy the complete tracking URL for use in your marketing campaigns."
];

const faqs = [
  {
    q: "What are UTM parameters?",
    a: "UTM (Urchin Tracking Module) parameters are tags appended to URLs that tell Google Analytics how visitors arrived at your site. The five standard parameters are: utm_source (where traffic comes from), utm_medium (the marketing channel), utm_campaign (the specific campaign), utm_term (paid search keywords), and utm_content (for differentiating ads/links)."
  },
  {
    q: "Which UTM parameters are required?",
    a: "utm_source, utm_medium, and utm_campaign are required for Google Analytics to properly attribute traffic. utm_term and utm_content are optional and used for more granular tracking."
  },
  {
    q: "Do UTM parameters affect SEO?",
    a: "No. UTM parameters are used by analytics tools only and don't affect search rankings. However, you should use canonical tags on landing pages and avoid internal linking with UTM parameters, as this can fragment analytics data."
  },
  {
    q: "Is this builder safe for my campaigns?",
    a: "Yes. URLs are constructed entirely in your browser. No campaign data or URLs are stored or transmitted to any server."
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "UTM Campaign URL Builder",
  "url": "https://instanttoolshub.com/url-encoder-decoder/utm-builder",
  "description": "Free online UTM campaign URL builder. Create tracking URLs for Google Analytics instantly in your browser.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "isAccessibleForFree": true,
  "provider": { "@type": "Organization", "name": "InstantToolsHub", "url": "https://instanttoolshub.com" }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Generate properly encoded UTM campaign tracking URLs for Google Analytics attribution.</p>
  </div>

  <div class="panel glass">
    <div class="panel-header">
      <span>UTM Builder</span>
      <div class="panel-header-actions">
        <button class="btn btn-outline btn-xs" id="btn-clear">Clear</button>
        <button class="btn btn-primary btn-xs copy-btn" id="btn-copy">Copy URL</button>
      </div>
    </div>
    <div class="panel-body">
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label">Website URL <span class="required">*</span></label>
          <input type="url" id="utm-url" placeholder="https://example.com/landing-page" class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label">Campaign Source <span class="required">*</span></label>
          <input type="text" id="utm-source" placeholder="google, newsletter, facebook" class="form-input" />
          <span class="form-hint">Where the traffic originates from</span>
        </div>
        <div class="form-group">
          <label class="form-label">Campaign Medium <span class="required">*</span></label>
          <input type="text" id="utm-medium" placeholder="cpc, email, social, banner" class="form-input" />
          <span class="form-hint">The marketing channel</span>
        </div>
        <div class="form-group">
          <label class="form-label">Campaign Name <span class="required">*</span></label>
          <input type="text" id="utm-campaign" placeholder="summer_sale, product_launch" class="form-input" />
          <span class="form-hint">Your campaign identifier</span>
        </div>
        <div class="form-group">
          <label class="form-label">Campaign Term <span class="optional">(optional)</span></label>
          <input type="text" id="utm-term" placeholder="running+shoes, best+deals" class="form-input" />
          <span class="form-hint">Paid search keywords</span>
        </div>
        <div class="form-group">
          <label class="form-label">Campaign Content <span class="optional">(optional)</span></label>
          <input type="text" id="utm-content" placeholder="hero_banner, sidebar_cta" class="form-input" />
          <span class="form-hint">Differentiate ads or links</span>
        </div>
      </div>
      <div class="output-section">
        <label class="form-label">Generated UTM URL</label>
        <textarea id="utm-output" readonly placeholder="Fill in the fields above to generate your UTM URL..." class="form-textarea output-area"></textarea>
      </div>
    </div>
  </div>

  <div class="sub-tools-nav glass">
    <h3>More URL Tools</h3>
    <div class="links-list">
      <a href="/url-encoder-decoder">URL Encoder & Decoder</a>
      <a href="/url-encoder-decoder/query-parser">Query String Parser</a>
    </div>
  </div>

  <RelatedTools currentTool="url-encoder-decoder" />

  <SEOContent 
    toolName={pageHeading}
    description="UTM parameters are the standard mechanism for attributing website traffic to specific marketing campaigns in Google Analytics. By appending utm_source, utm_medium, utm_campaign (and optionally utm_term and utm_content) to your destination URLs, you create a complete attribution trail from ad click to conversion. This builder ensures parameters are properly percent-encoded, prevents common mistakes like spaces in values, and generates copy-ready URLs for email campaigns, social media posts, paid ads, and affiliate links."
    howToUse={howToUse}
    faqs={faqs}
  />
</Layout>

<style>
  .tool-header { margin-bottom: 1.5rem; }
  .tool-header h1 { color: #fff; margin-bottom: 0.5rem; }
  .panel { display: flex; flex-direction: column; overflow: hidden; }
  .panel-header { padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.4); font-weight: 600; font-size: 0.95rem; }
  .panel-header-actions { display: flex; gap: 0.5rem; }
  .panel-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.3rem; }
  .form-group:first-child { grid-column: 1 / -1; }
  .form-label { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .required { color: #f87171; }
  .optional { color: var(--text-muted); font-weight: 400; text-transform: none; }
  .form-input { width: 100%; padding: 0.65rem 1rem; font-size: 0.9rem; background: #030712; border: 1px solid var(--border-light); border-radius: var(--radius-sm); color: #e2e8f0; outline: none; }
  .form-input:focus { border-color: var(--accent-primary); }
  .form-hint { font-size: 0.7rem; color: var(--text-muted); }
  .output-section { margin-top: 0.5rem; }
  .output-area { width: 100%; min-height: 80px; padding: 0.75rem 1rem; font-family: var(--font-mono); font-size: 0.85rem; background: #030712; border: 1px solid var(--border-light); border-radius: var(--radius-sm); color: #60a5fa; resize: none; outline: none; word-break: break-all; }
  .sub-tools-nav { padding: 1.5rem; margin-top: 2rem; }
  .sub-tools-nav h3 { color: #fff; font-size: 1.15rem; margin-bottom: 0.75rem; }
  .links-list { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .links-list a { color: var(--accent-primary); font-weight: 500; text-decoration: underline; font-size: 0.95rem; }
  .links-list a:hover { color: #fff; }
  @media (max-width: 768px) { .form-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const urlInput = document.getElementById('utm-url') as HTMLInputElement;
  const source = document.getElementById('utm-source') as HTMLInputElement;
  const medium = document.getElementById('utm-medium') as HTMLInputElement;
  const campaign = document.getElementById('utm-campaign') as HTMLInputElement;
  const term = document.getElementById('utm-term') as HTMLInputElement;
  const content = document.getElementById('utm-content') as HTMLInputElement;
  const output = document.getElementById('utm-output') as HTMLTextAreaElement;
  const btnCopy = document.getElementById('btn-copy');
  const btnClear = document.getElementById('btn-clear');

  const inputs = [urlInput, source, medium, campaign, term, content].filter(Boolean);

  function buildUTM() {
    if (!urlInput || !output) return;
    const base = urlInput.value.trim();
    if (!base) { output.value = ''; return; }

    const params = new URLSearchParams();
    if (source?.value.trim()) params.set('utm_source', source.value.trim());
    if (medium?.value.trim()) params.set('utm_medium', medium.value.trim());
    if (campaign?.value.trim()) params.set('utm_campaign', campaign.value.trim());
    if (term?.value.trim()) params.set('utm_term', term.value.trim());
    if (content?.value.trim()) params.set('utm_content', content.value.trim());

    const queryStr = params.toString();
    if (!queryStr) { output.value = base; return; }

    const separator = base.includes('?') ? '&' : '?';
    output.value = base + separator + queryStr;
  }

  inputs.forEach(input => { if (input) input.addEventListener('input', buildUTM); });
  if (btnCopy && output) btnCopy.addEventListener('click', () => {
    if (output.value) navigator.clipboard.writeText(output.value).then(() => { btnCopy.textContent = 'Copied!'; setTimeout(() => { btnCopy.textContent = 'Copy URL'; }, 2000); });
  });
  if (btnClear) btnClear.addEventListener('click', () => { inputs.forEach(i => { if (i) i.value = ''; }); if (output) output.value = ''; });
</script>
