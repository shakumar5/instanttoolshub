---
import Layout from '../layouts/Layout.astro';

const tools = [
  {
    id: "json-formatter",
    name: "JSON Formatter & Validator",
    desc: "Format, minify, validate, and convert JSON data. Inspect tree views, run visual diff comparisons, or convert JSON to CSV instantly.",
    href: "/json-formatter",
    color: "#10b981",
    glow: "rgba(16, 185, 129, 0.15)",
    keywords: "json formatter, json beautifier, json validator, json minifier",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`
  },
  {
    id: "base64",
    name: "Base64 Encoder & Decoder",
    desc: "Encode or decode raw text, convert images to Base64 data URLs, decode files, or preview generated images completely in the browser.",
    href: "/base64",
    color: "#06b6d4",
    glow: "rgba(6, 182, 212, 0.15)",
    keywords: "base64 encoder, base64 decoder, image to base64, base64 to image",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>`
  },
  {
    id: "url-encoder-decoder",
    name: "URL Encoder & Decoder",
    desc: "Perform URL percent encoding and decoding, batch process multiple URLs, parse query string parameters into structured tables, and build UTM campaigns.",
    href: "/url-encoder-decoder",
    color: "#3b82f6",
    glow: "rgba(59, 130, 246, 0.15)",
    keywords: "url encoder, url decoder, percent encoding, query string parser",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>`
  },
  {
    id: "regex-tester",
    name: "RegEx Tester & AI Generator",
    desc: "Test regular expressions with live match highlighting, capture group details, and cheat sheets. Generate complex expressions from English descriptions using AI.",
    href: "/regex-tester",
    color: "#f59e0b",
    glow: "rgba(245, 158, 11, 0.15)",
    keywords: "regex tester, regex generator, regular expression, regex online",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>`
  },
  {
    id: "jwt-decoder",
    name: "JWT Decoder & Debugger",
    desc: "Decode, verify, and inspect JSON Web Token headers, payloads, and signatures. Track token expiration timers and generate test tokens locally.",
    href: "/jwt-decoder",
    color: "#8b5cf6",
    glow: "rgba(139, 92, 246, 0.15)",
    keywords: "jwt decoder, jwt debugger, json web token, jwt parser",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>`
  },
  {
    id: "code-minifier-beautifier",
    name: "CSS / JS / HTML Minifier & Beautifier",
    desc: "Compress or format CSS, Javascript, and HTML files. View real-time file size savings, batch upload resources, and retrieve production-ready minified code.",
    href: "/code-minifier-beautifier",
    color: "#ec4899",
    glow: "rgba(236, 72, 153, 0.15)",
    keywords: "css minifier, javascript minifier, html minifier, code beautifier",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"></path><path d="m14.5 4-5 16"></path></svg>`
  },
  {
    id: "markdown-editor",
    name: "Markdown Editor & README Creator",
    desc: "Write Markdown code with split-screen real-time preview. Use professional templates to compile outstanding GitHub README profiles and download outputs.",
    href: "/markdown-editor",
    color: "#a855f7",
    glow: "rgba(168, 85, 247, 0.15)",
    keywords: "markdown editor, readme generator, markdown preview, github readme",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg>`
  },
  {
    id: "color-converter",
    name: "Color Converter & Palette Picker",
    desc: "Pick colors, build modern gradients, extract palettes from images, verify WCAG accessibility contrast scores, and convert HEX, RGB, HSL, and CMYK formats.",
    href: "/color-converter",
    color: "#14b8a6",
    glow: "rgba(20, 184, 166, 0.15)",
    keywords: "color converter, hex to rgb, color picker, palette generator",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 14.7255 3.09032 17.1962 4.85857 19C5.35857 19.5 5.5 20 5.5 20.5C5.5 21.3284 6.17157 22 7 22H12Z"></path><circle cx="7.5" cy="10.5" r="1.5"></circle><circle cx="11.5" cy="7.5" r="1.5"></circle><circle cx="16.5" cy="9.5" r="1.5"></circle><circle cx="15.5" cy="14.5" r="1.5"></circle></svg>`
  },
  {
    id: "timestamp",
    name: "Unix Epoch Timestamp Converter",
    desc: "Convert Unix timestamps to human-readable dates and vice versa. Adjust timezone settings, evaluate relative times, and parse cron expressions.",
    href: "/timestamp",
    color: "#f43f5e",
    glow: "rgba(244, 63, 94, 0.15)",
    keywords: "unix timestamp, epoch converter, date converter, cron parser",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`
  },
  {
    id: "hash-generator",
    name: "Hash & HMAC Generator",
    desc: "Generate secure cryptographic hashes (MD5, SHA-1, SHA-256, SHA-512) and HMAC keys. Calculate hashes of local files safely and privately.",
    href: "/hash-generator",
    color: "#e11d48",
    glow: "rgba(225, 29, 72, 0.15)",
    keywords: "sha256 generator, md5 hash, hmac generator, file checksum",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`
  }
];

const stats = [
  { value: "10+", label: "Developer Tools" },
  { value: "0 B", label: "Data Uploaded" },
  { value: "100%", label: "Client-Side" },
  { value: "<1ms", label: "Execution Speed" }
];

// ItemList schema for the tools (helps Google show rich carousel)
const toolListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": tools.map((tool, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": tool.name,
    "url": `https://instanttoolshub.com${tool.href}`
  }))
};
---

<Layout 
  title="Free Online Developer Tools — JSON Formatter, Base64, URL Encoder, RegEx Tester" 
  description="ToolsHub is a collection of 10+ free, blazing-fast, 100% client-side developer utilities including JSON formatting, Base64 conversion, URL encoding, RegEx testing, JWT decoding, code minification, Markdown editing, color conversion, timestamp converter, and hash generation. No data ever leaves your browser."
  keywords="developer tools, json formatter online, base64 encoder decoder, url encoder online, regex tester, jwt decoder, code minifier, markdown editor, color converter, unix timestamp, hash generator, free online tools, web developer utilities"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(toolListSchema)} />
  <section class="hero-section" id="hero">
    <div class="hero-content">
      <div class="badge">⚡ 100% Client-Side • Zero Latency • Maximum Privacy</div>
      <h1>The Ultimate Free Developer Toolkit</h1>
      <p class="hero-subtitle">Format JSON, encode Base64, test RegEx, decode JWTs, minify code, and more — all instantly in your browser. Your data never touches a server.</p>
    </div>
    <div class="stats-bar">
      {stats.map(stat => (
        <div class="stat-item">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>

    <div class="hero-search-bar glass" id="search-container">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="dashboard-search" placeholder="Search tools — json, base64, jwt, regex, url, hash..." aria-label="Search developer tools" />
      <kbd class="search-kbd">/</kbd>
    </div>
  </section>
  <section class="tools-section" id="tools" aria-label="Developer tools list">
    <h2 class="section-title">All Tools</h2>
    <div class="dashboard-grid" id="dashboard-grid">
      {tools.map(tool => (
        <a 
          href={tool.href} 
          class="tool-card glass" 
          id={`tool-${tool.id}`}
          style={`--accent-color: ${tool.color}; --accent-glow-color: ${tool.glow};`}
          data-title={tool.name.toLowerCase()}
          data-desc={tool.desc.toLowerCase()}
          data-keywords={tool.keywords}
          aria-label={`Open ${tool.name}`}
        >
          <div class="tool-card-icon" set:html={tool.icon} />
          <h3 class="tool-card-title">{tool.name}</h3>
          <p class="tool-card-desc">{tool.desc}</p>
          <span class="tool-card-link">
            Open Tool 
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </a>
      ))}
    </div>
    <div id="dashboard-no-results" class="no-results" style="display: none; padding: 4rem 2rem; text-align: center;">
      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity: 0.5; margin-bottom: 1rem;"><circle cx="12" cy="12" r="10"></circle><line x1="8" y1="12" x2="16" y2="12"></line></svg>
      <h3>No utilities match your search query</h3>
      <p>Try searching for core keywords like 'json', 'url', 'base64', 'css', or 'date'.</p>
    </div>
  </section>
  <section class="educational-section glass" id="features">
    <h2 class="edu-section-title">Why Developers Choose ToolsHub</h2>
    <div class="edu-grid">
      <div class="edu-card">
        <div class="edu-icon">🔒</div>
        <h3>100% Client-Side Privacy</h3>
        <p>Unlike other online utilities, ToolsHub performs all operations directly in your browser. Your JSON data, JWT tokens, and encoded strings never travel across the network. Your privacy is guaranteed by design.</p>
      </div>
      <div class="edu-card">
        <div class="edu-icon">⚡</div>
        <h3>Sub-millisecond Execution</h3>
        <p>Because all code runs client-side with zero network latency, execution is instant. Large-scale formatting and code compression are processed via the Web Crypto API and optimized algorithms for absolute speed.</p>
      </div>
      <div class="edu-card">
        <div class="edu-icon">📱</div>
        <h3>Premium Responsive Design</h3>
        <p>Designed with a premium dark theme and dynamic focus states, ToolsHub is fully optimized for desktop, tablet, and mobile views. Keep it pinned in your browser sidebar for instant access.</p>
      </div>
      <div class="edu-card">
        <div class="edu-icon">🛠️</div>
        <h3>10+ Professional Utilities</h3>
        <p>From JSON formatting to cryptographic hash generation, ToolsHub covers every common developer workflow in one unified, fast-loading site. No more switching between dozens of bookmark tabs.</p>
      </div>
    </div>
  </section>
  <section class="seo-content-section" id="about">
    <h2>Free Online Developer Tools — Trusted by Thousands of Engineers</h2>
    <div class="seo-text-grid">
      <div class="seo-text-block">
        <h3>JSON Formatter & Validator</h3>
        <p>Our <a href="/json-formatter">JSON Formatter</a> lets you paste raw JSON and instantly beautify, minify, or validate it. View your data as an interactive tree, perform visual diffs, or convert JSON to CSV — all without sending a single byte to any server. Whether you're debugging API responses or cleaning up configuration files, this tool handles it in milliseconds.</p>
      </div>
      <div class="seo-text-block">
        <h3>Base64 Encoder & Decoder</h3>
        <p>The <a href="/base64">Base64 tool</a> handles text encoding/decoding, image-to-Base64 conversion, and file processing entirely in-browser. Perfect for embedding images in CSS, encoding authentication headers, or decoding opaque data payloads from APIs and email headers.</p>
      </div>
      <div class="seo-text-block">
        <h3>URL Encoder & RegEx Tester</h3>
        <p>Our <a href="/url-encoder-decoder">URL Encoder/Decoder</a> handles percent encoding, query string parsing, and UTM campaign building. Pair it with the <a href="/regex-tester">RegEx Tester</a> for live match highlighting, capture group inspection, and an AI-powered pattern generator that converts plain English into working regular expressions.</p>
      </div>
      <div class="seo-text-block">
        <h3>JWT Decoder & Hash Generator</h3>
        <p>Inspect <a href="/jwt-decoder">JSON Web Tokens</a> by pasting them to see decoded headers, payloads, and signature verification. Use the <a href="/hash-generator">Hash Generator</a> to compute MD5, SHA-1, SHA-256, and SHA-512 checksums for text or files using the browser's native Web Crypto API — with HMAC support for keyed hashing.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero-section {
    text-align: center;
    padding: 2rem 0 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .badge {
    background: var(--accent-glow);
    color: var(--accent-primary);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 0.4rem 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 50px;
    letter-spacing: 0.04em;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    max-width: 650px;
    margin: 0 auto;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Stats Bar */
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    padding: 0.5rem 0;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 800;
    color: #fff;
    background: linear-gradient(135deg, var(--accent-primary), #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  /* Search Bar */
  .hero-search-bar {
    width: 100%;
    max-width: 650px;
    display: flex;
    align-items: center;
    padding: 0.25rem 1rem;
    border-radius: var(--radius-md);
    position: relative;
  }

  .search-icon {
    color: var(--text-muted);
    pointer-events: none;
    flex-shrink: 0;
  }

  #dashboard-search {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-primary);
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: 1rem;
  }

  .search-kbd {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-light);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  /* Tools Section */
  .tools-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-title {
    font-size: 1.5rem;
    color: #fff;
  }

  /* Education Section */
  .educational-section {
    padding: 2.5rem;
    margin-top: 2rem;
  }

  .edu-section-title {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 2rem;
    text-align: center;
  }

  .edu-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (max-width: 900px) {
    .edu-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .edu-card {
    padding: 1.5rem;
    background: rgba(4, 6, 10, 0.3);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition-fast);
  }

  .edu-card:hover {
    border-color: var(--accent-primary);
  }

  .edu-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .edu-card h3 {
    margin-bottom: 0.75rem;
    color: #fff;
    font-size: 1.1rem;
  }

  .edu-card p {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* SEO Content Section */
  .seo-content-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-light);
  }

  .seo-content-section > h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 2rem;
  }

  .seo-text-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .seo-text-grid {
      grid-template-columns: 1fr;
    }
  }

  .seo-text-block h3 {
    font-size: 1.1rem;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .seo-text-block p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .seo-text-block a {
    color: var(--accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .seo-text-block a:hover {
    color: #fff;
  }

  @media (max-width: 600px) {
    .stats-bar {
      gap: 1.5rem;
    }
    .stat-value {
      font-size: 1.4rem;
    }
  }
</style>

<script>
  // Dashboard card search filter
  const searchInput = document.getElementById('dashboard-search') as HTMLInputElement | null;
  const toolCards = document.querySelectorAll('.tool-card');
  const noResultsDiv = document.getElementById('dashboard-no-results');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.trim().toLowerCase();
      let matchCount = 0;

      toolCards.forEach((card) => {
        const title = card.getAttribute('data-title') || '';
        const desc = card.getAttribute('data-desc') || '';
        const kw = card.getAttribute('data-keywords') || '';

        if (title.includes(query) || desc.includes(query) || kw.includes(query)) {
          (card as HTMLElement).style.display = 'flex';
          matchCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      if (noResultsDiv) {
        noResultsDiv.style.display = matchCount === 0 ? 'block' : 'none';
      }
    });

    // Keyboard shortcut: press "/" to focus search
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput.focus();
      }
    });
  }
</script>
