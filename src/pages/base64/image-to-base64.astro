---
import Layout from '../../layouts/Layout.astro';
import SEOContent from '../../components/SEOContent.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const toolName = "Image to Base64 Converter Online — Free, Instant, Private";
const pageHeading = "Image to Base64 Converter";
const activeTool = "base64";
const accentColor = "#06b6d4";
const accentGlow = "rgba(6, 182, 212, 0.15)";

const seoDescription = "Convert images (PNG, JPG, WebP, SVG, GIF) to Base64 Data URLs instantly in your browser. Embed images directly in HTML and CSS without extra HTTP requests — 100% free, no upload.";
const seoKeywords = "image to base64, convert image to base64, png to base64, jpg to base64, image to data uri, base64 image converter, image to base64 online, svg to base64";

const howToUse = [
  "Drag and drop an image (PNG, JPG, WebP, SVG, or GIF) onto the drop zone, or click to browse files.",
  "The tool reads the image locally and generates the complete Base64 Data URI string instantly.",
  "The output includes the full data:image/type;base64,... prefix ready to paste into HTML img src or CSS background-image.",
  "File metadata (name, size, MIME type) is displayed for reference.",
  "Click 'Copy' to copy the full Data URI to your clipboard for embedding in your code."
];

const faqs = [
  {
    q: "What is a Base64 Data URI for images?",
    a: "A Data URI embeds the image directly in HTML or CSS as a Base64-encoded string (format: data:image/png;base64,...). The browser renders the image without making a separate HTTP request, which can improve page load for small images."
  },
  {
    q: "When should I use Base64 images?",
    a: "Use Base64 for small images (icons, logos under 10KB) to reduce HTTP requests. For larger images, regular file references are better because Base64 increases size by 33% and can't be cached independently."
  },
  {
    q: "What image formats are supported?",
    a: "This tool supports PNG, JPEG, WebP, SVG, GIF, and BMP. The MIME type is automatically detected and included in the Data URI prefix."
  },
  {
    q: "Is my image uploaded anywhere?",
    a: "No. The image is read locally using the FileReader API. It never leaves your device — all processing happens in your browser."
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Image to Base64 Converter",
  "url": "https://instanttoolshub.com/base64/image-to-base64",
  "description": "Free online image to Base64 converter. Convert PNG, JPG, WebP, SVG, and GIF images to Data URIs instantly in your browser.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "isAccessibleForFree": true,
  "provider": { "@type": "Organization", "name": "InstantToolsHub", "url": "https://instanttoolshub.com" }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Convert any image to a Base64 Data URI for embedding directly in HTML or CSS.</p>
  </div>

  <div class="panel glass">
    <div class="panel-header">
      <span>Image → Base64 Data URI</span>
      <div class="panel-header-actions">
        <button class="btn btn-outline btn-xs" id="btn-clear">Clear</button>
        <button class="btn btn-primary btn-xs copy-btn" id="btn-copy">Copy Data URI</button>
      </div>
    </div>
    <div class="panel-body">
      <div class="upload-section">
        <div class="drag-zone" id="drop-zone">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-bottom:0.5rem;opacity:0.7;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
          <p>Drag & Drop Image or Click to Browse</p>
          <span class="file-limits">Supports PNG, JPG, WebP, SVG, GIF (Max 10MB)</span>
          <input type="file" id="file-input" accept="image/*" class="hidden" />
        </div>
        <div id="file-meta" class="file-meta hidden"></div>
      </div>
      <div class="output-section">
        <div class="split-label">Base64 Data URI Output</div>
        <textarea id="base64-output" readonly placeholder="Base64 Data URI will appear here after selecting an image..." class="form-textarea code-textarea output"></textarea>
      </div>
    </div>
  </div>

  <div class="sub-tools-nav glass">
    <h3>More Base64 Tools</h3>
    <div class="links-list">
      <a href="/base64">Base64 Encoder & Decoder</a>
      <a href="/base64/encoder">Base64 Encoder</a>
      <a href="/base64/decoder">Base64 Decoder</a>
      <a href="/base64/base64-to-image">Base64 to Image</a>
      <a href="/base64/file-to-base64">File to Base64</a>
    </div>
  </div>

  <RelatedTools currentTool="base64" />

  <SEOContent 
    toolName={pageHeading}
    description="Converting images to Base64 Data URIs embeds image data directly in your HTML or CSS as a text string. The browser decodes and renders the image without making a separate HTTP request. This technique is most effective for small images (icons, logos, UI elements under 10KB) where eliminating the request overhead outweighs the 33% size increase from Base64 encoding. The FileReader API reads image bytes locally and produces a complete data:image/type;base64,... string ready for use in img src attributes or CSS background-image properties."
    howToUse={howToUse}
    faqs={faqs}
  />
</Layout>

<style>
  .tool-header { margin-bottom: 1.5rem; }
  .tool-header h1 { color: #fff; margin-bottom: 0.5rem; }
  .panel { display: flex; flex-direction: column; min-height: 500px; overflow: hidden; }
  .panel-header { padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.4); font-weight: 600; font-size: 0.95rem; }
  .panel-header-actions { display: flex; gap: 0.5rem; }
  .panel-body { flex-grow: 1; display: flex; flex-direction: column; padding: 1.5rem; gap: 1.5rem; }
  .upload-section { display: flex; flex-direction: column; gap: 1rem; }
  .drag-zone { border: 2px dashed var(--border-light); border-radius: var(--radius-md); background: rgba(255,255,255,0.01); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2.5rem 1.5rem; text-align: center; cursor: pointer; transition: all var(--transition-fast); }
  .drag-zone:hover, .drag-zone.dragover { border-color: var(--accent-primary); background: var(--accent-glow); }
  .drag-zone p { font-size: 0.9rem; font-weight: 500; color: var(--text-primary); margin-bottom: 0.25rem; }
  .file-limits { font-size: 0.75rem; color: var(--text-muted); }
  .file-meta { padding: 0.75rem 1rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border-light); border-radius: var(--radius-sm); font-size: 0.8rem; color: var(--text-secondary); }
  .output-section { display: flex; flex-direction: column; flex-grow: 1; }
  .split-label { padding: 0.5rem 0; font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
  .code-textarea { width: 100%; min-height: 150px; flex-grow: 1; border: 1px solid var(--border-light); border-radius: var(--radius-sm); padding: 1rem; font-family: var(--font-mono); font-size: 0.8rem; background: #030712; color: #22d3ee; resize: none; outline: none; }
  .hidden { display: none !important; }
  .sub-tools-nav { padding: 1.5rem; margin-top: 2rem; }
  .sub-tools-nav h3 { color: #fff; font-size: 1.15rem; margin-bottom: 0.75rem; }
  .links-list { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .links-list a { color: var(--accent-primary); font-weight: 500; text-decoration: underline; font-size: 0.95rem; }
  .links-list a:hover { color: #fff; }
</style>

<script>
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const output = document.getElementById('base64-output') as HTMLTextAreaElement;
  const fileMeta = document.getElementById('file-meta');
  const btnCopy = document.getElementById('btn-copy');
  const btnClear = document.getElementById('btn-clear');

  if (dropZone && fileInput) {
    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragover'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
    dropZone.addEventListener('drop', (e) => { e.preventDefault(); dropZone.classList.remove('dragover'); if (e.dataTransfer?.files[0]) handleFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) handleFile(fileInput.files[0]); });
  }

  function handleFile(file: File) {
    if (!file.type.startsWith('image/')) { if (output) output.value = 'Error: Selected file is not an image.'; return; }
    const reader = new FileReader();
    reader.onload = (e) => {
      const dataUrl = e.target?.result as string;
      if (output) output.value = dataUrl;
      if (fileMeta) { fileMeta.innerHTML = `<strong>File:</strong> ${file.name} | <strong>Size:</strong> ${(file.size/1024).toFixed(2)} KB | <strong>Type:</strong> ${file.type}`; fileMeta.classList.remove('hidden'); }
    };
    reader.readAsDataURL(file);
  }

  if (btnCopy && output) btnCopy.addEventListener('click', () => {
    if (output.value) navigator.clipboard.writeText(output.value).then(() => { btnCopy.textContent = 'Copied!'; setTimeout(() => { btnCopy.textContent = 'Copy Data URI'; }, 2000); });
  });
  if (btnClear && output && fileMeta) btnClear.addEventListener('click', () => { output.value = ''; fileMeta.classList.add('hidden'); });
</script>
