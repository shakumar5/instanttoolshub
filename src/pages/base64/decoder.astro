---
import Layout from '../../layouts/Layout.astro';
import SEOContent from '../../components/SEOContent.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const toolName = "Base64 Decoder Online — Free, Instant, Private";
const pageHeading = "Base64 Decoder";
const activeTool = "base64";
const accentColor = "#06b6d4";
const accentGlow = "rgba(6, 182, 212, 0.15)";

const seoDescription = "Decode Base64 strings back to plain text instantly in your browser. Supports UTF-8, validates input, and shows errors for invalid Base64 — 100% free, no data uploaded.";
const seoKeywords = "base64 decoder, decode base64, base64 to text, base64 decode online, base64 decoder free, convert base64 to string, base64 to utf8";

const howToUse = [
  "Paste a Base64-encoded string into the input area.",
  "Click 'Decode' to convert it back to the original plain text.",
  "If the string is invalid Base64, an error message explains what went wrong.",
  "The decoder handles UTF-8 encoded content correctly, restoring multi-byte characters and emojis.",
  "Click 'Copy' to copy the decoded text to your clipboard."
];

const faqs = [
  {
    q: "What characters are valid in Base64?",
    a: "Standard Base64 uses A-Z, a-z, 0-9, +, and / (64 characters total). The = character is used for padding at the end. Base64URL variant uses - and _ instead of + and / for URL-safe encoding."
  },
  {
    q: "Why does my Base64 string fail to decode?",
    a: "Common causes: extra whitespace or line breaks in the string, invalid characters (anything outside the Base64 alphabet), or incorrect padding. Remove any surrounding quotes, trim whitespace, and ensure the string length is a multiple of 4."
  },
  {
    q: "Can I decode Base64URL strings?",
    a: "This decoder handles standard Base64. For Base64URL strings (using - and _ instead of + and /), replace those characters before decoding: replace - with + and _ with /, then add = padding if needed."
  },
  {
    q: "Is decoding safe for sensitive data?",
    a: "Yes. All decoding happens locally in your browser. No data is transmitted to any server."
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Base64 Decoder",
  "url": "https://instanttoolshub.com/base64/decoder",
  "description": "Free online Base64 decoder. Convert Base64 strings to plain text instantly in your browser.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "isAccessibleForFree": true,
  "provider": { "@type": "Organization", "name": "InstantToolsHub", "url": "https://instanttoolshub.com" }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Convert Base64-encoded strings back to readable plain text with UTF-8 support.</p>
  </div>

  <div class="panel glass">
    <div class="panel-header">
      <span>Base64 → Text</span>
      <div class="panel-header-actions">
        <button class="btn btn-outline btn-xs" id="btn-clear">Clear</button>
        <button class="btn btn-primary btn-xs" id="btn-decode">Decode</button>
        <button class="btn btn-primary btn-xs copy-btn" id="btn-copy">Copy</button>
      </div>
    </div>
    <div class="panel-body">
      <div class="split-container">
        <div class="split-pane">
          <div class="split-label">Base64 Input</div>
          <textarea id="base64-input" placeholder="Paste Base64 string here..." class="form-textarea code-textarea"></textarea>
        </div>
        <div class="split-pane">
          <div class="split-label">Decoded Text Output</div>
          <textarea id="text-output" readonly placeholder="Decoded text will appear here..." class="form-textarea code-textarea output"></textarea>
        </div>
      </div>
    </div>
  </div>

  <div class="sub-tools-nav glass">
    <h3>More Base64 Tools</h3>
    <div class="links-list">
      <a href="/base64">Base64 Encoder & Decoder</a>
      <a href="/base64/encoder">Base64 Encoder</a>
      <a href="/base64/image-to-base64">Image to Base64</a>
      <a href="/base64/base64-to-image">Base64 to Image</a>
      <a href="/base64/file-to-base64">File to Base64</a>
    </div>
  </div>

  <RelatedTools currentTool="base64" />

  <SEOContent 
    toolName={pageHeading}
    description="Base64 decoding reverses the encoding process — converting ASCII Base64 characters back into the original binary data. The algorithm maps each Base64 character to its 6-bit value, concatenates these into a bitstream, then splits into 8-bit bytes to reconstruct the original data. This decoder correctly handles UTF-8 multi-byte sequences, restoring characters that span multiple bytes (accented letters, CJK characters, emojis) to their original form."
    howToUse={howToUse}
    faqs={faqs}
  />
</Layout>

<style>
  .tool-header { margin-bottom: 1.5rem; }
  .tool-header h1 { color: #fff; margin-bottom: 0.5rem; }
  .panel { display: flex; flex-direction: column; min-height: 400px; height: 500px; overflow: hidden; }
  .panel-header { padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.4); font-weight: 600; font-size: 0.95rem; }
  .panel-header-actions { display: flex; gap: 0.5rem; }
  .panel-body { flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; }
  .split-container { display: grid; grid-template-columns: 1fr 1fr; height: 100%; }
  .split-pane { display: flex; flex-direction: column; border-right: 1px solid var(--border-light); }
  .split-pane:last-child { border-right: none; }
  .split-label { padding: 0.5rem 1.25rem; background: rgba(15, 23, 42, 0.5); border-bottom: 1px solid var(--border-light); font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
  .code-textarea { width: 100%; height: 100%; flex-grow: 1; border: none; padding: 1.25rem; font-family: var(--font-mono); font-size: 0.85rem; background: #030712; color: #e2e8f0; resize: none; outline: none; }
  .code-textarea.output { color: #22d3ee; }
  .sub-tools-nav { padding: 1.5rem; margin-top: 2rem; }
  .sub-tools-nav h3 { color: #fff; font-size: 1.15rem; margin-bottom: 0.75rem; }
  .links-list { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .links-list a { color: var(--accent-primary); font-weight: 500; text-decoration: underline; font-size: 0.95rem; }
  .links-list a:hover { color: #fff; }
  @media (max-width: 768px) { .split-container { grid-template-columns: 1fr; } }
</style>

<script>
  const input = document.getElementById('base64-input') as HTMLTextAreaElement;
  const output = document.getElementById('text-output') as HTMLTextAreaElement;
  const btnDecode = document.getElementById('btn-decode');
  const btnClear = document.getElementById('btn-clear');
  const btnCopy = document.getElementById('btn-copy');

  function decode() {
    if (!input || !output) return;
    const val = input.value.trim();
    if (!val) { output.value = ''; return; }
    try {
      const binary = atob(val);
      const bytes = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
      output.value = new TextDecoder().decode(bytes);
    } catch (e: any) {
      output.value = 'Error: ' + e.message;
    }
  }

  if (btnDecode) btnDecode.addEventListener('click', decode);
  if (btnClear && input && output) btnClear.addEventListener('click', () => { input.value = ''; output.value = ''; });
  if (btnCopy && output) btnCopy.addEventListener('click', () => {
    if (output.value) navigator.clipboard.writeText(output.value).then(() => { btnCopy.textContent = 'Copied!'; setTimeout(() => { btnCopy.textContent = 'Copy'; }, 2000); });
  });
</script>
