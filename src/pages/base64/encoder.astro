---
import Layout from '../../layouts/Layout.astro';
import SEOContent from '../../components/SEOContent.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const toolName = "Base64 Encoder Online — Free, Instant, Private";
const pageHeading = "Base64 Encoder";
const activeTool = "base64";
const accentColor = "#06b6d4";
const accentGlow = "rgba(6, 182, 212, 0.15)";

const seoDescription = "Encode text to Base64 instantly in your browser. Convert any string, UTF-8 text, or special characters to Base64 format — 100% free, client-side, no data uploaded.";
const seoKeywords = "base64 encoder, encode to base64, text to base64, base64 encode online, base64 encoder free, convert string to base64, utf8 to base64";

const howToUse = [
  "Type or paste any plain text into the input area.",
  "Click 'Encode' to instantly convert it to a Base64-encoded string.",
  "The encoder supports full UTF-8 — emojis, accented characters, and multi-byte text are handled correctly.",
  "Click 'Copy' to copy the Base64 output to your clipboard.",
  "Use the encoded string in API payloads, email headers, or data URIs."
];

const faqs = [
  {
    q: "What is Base64 encoding used for?",
    a: "Base64 encoding converts binary or text data into ASCII characters, making it safe to transmit through text-only channels like email (MIME), JSON payloads, URL parameters, and HTML data attributes."
  },
  {
    q: "Does Base64 encoding encrypt data?",
    a: "No. Base64 is an encoding scheme, not encryption. Anyone can decode a Base64 string back to the original data. Do not use Base64 as a security measure — use actual encryption (AES, RSA) for sensitive data."
  },
  {
    q: "How much larger does Base64 make my data?",
    a: "Base64 increases data size by approximately 33%. Every 3 bytes of input become 4 Base64 characters. For example, a 100-byte input produces about 133 characters of Base64 output."
  },
  {
    q: "Does this handle UTF-8 characters?",
    a: "Yes. The encoder uses TextEncoder to convert UTF-8 text (including emojis and accented characters) to bytes before encoding, ensuring correct Base64 output for any Unicode text."
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Base64 Encoder",
  "url": "https://instanttoolshub.com/base64/encoder",
  "description": "Free online Base64 encoder. Convert text to Base64 instantly in your browser.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "isAccessibleForFree": true,
  "provider": { "@type": "Organization", "name": "InstantToolsHub", "url": "https://instanttoolshub.com" }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Convert any text to Base64-encoded format instantly — supports UTF-8, emojis, and special characters.</p>
  </div>

  <div class="panel glass">
    <div class="panel-header">
      <span>Text → Base64</span>
      <div class="panel-header-actions">
        <button class="btn btn-outline btn-xs" id="btn-clear">Clear</button>
        <button class="btn btn-primary btn-xs" id="btn-encode">Encode</button>
        <button class="btn btn-primary btn-xs copy-btn" id="btn-copy">Copy</button>
      </div>
    </div>
    <div class="panel-body">
      <div class="split-container">
        <div class="split-pane">
          <div class="split-label">Plain Text Input</div>
          <textarea id="text-input" placeholder="Type or paste text to encode..." class="form-textarea code-textarea"></textarea>
        </div>
        <div class="split-pane">
          <div class="split-label">Base64 Output</div>
          <textarea id="base64-output" readonly placeholder="Encoded Base64 will appear here..." class="form-textarea code-textarea output"></textarea>
        </div>
      </div>
    </div>
  </div>

  <div class="sub-tools-nav glass">
    <h3>More Base64 Tools</h3>
    <div class="links-list">
      <a href="/base64">Base64 Encoder & Decoder</a>
      <a href="/base64/decoder">Base64 Decoder</a>
      <a href="/base64/image-to-base64">Image to Base64</a>
      <a href="/base64/base64-to-image">Base64 to Image</a>
      <a href="/base64/file-to-base64">File to Base64</a>
    </div>
  </div>

  <RelatedTools currentTool="base64" />

  <SEOContent 
    toolName={pageHeading}
    description="Base64 encoding converts arbitrary binary data into a string of 64 printable ASCII characters. The algorithm processes input in groups of 3 bytes (24 bits), splitting them into four 6-bit segments, each mapped to a character from the Base64 alphabet (A-Z, a-z, 0-9, +, /). Padding with = characters ensures the output length is always a multiple of 4. This encoding is essential for embedding binary data in text-only formats like JSON, XML, email (MIME), and URL parameters."
    howToUse={howToUse}
    faqs={faqs}
  />
</Layout>

<style>
  .tool-header { margin-bottom: 1.5rem; }
  .tool-header h1 { color: #fff; margin-bottom: 0.5rem; }
  .panel { display: flex; flex-direction: column; min-height: 400px; height: 500px; overflow: hidden; }
  .panel-header { padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.4); font-weight: 600; font-size: 0.95rem; }
  .panel-header-actions { display: flex; gap: 0.5rem; }
  .panel-body { flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; }
  .split-container { display: grid; grid-template-columns: 1fr 1fr; height: 100%; }
  .split-pane { display: flex; flex-direction: column; border-right: 1px solid var(--border-light); }
  .split-pane:last-child { border-right: none; }
  .split-label { padding: 0.5rem 1.25rem; background: rgba(15, 23, 42, 0.5); border-bottom: 1px solid var(--border-light); font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
  .code-textarea { width: 100%; height: 100%; flex-grow: 1; border: none; padding: 1.25rem; font-family: var(--font-mono); font-size: 0.85rem; background: #030712; color: #e2e8f0; resize: none; outline: none; }
  .code-textarea.output { color: #22d3ee; }
  .sub-tools-nav { padding: 1.5rem; margin-top: 2rem; }
  .sub-tools-nav h3 { color: #fff; font-size: 1.15rem; margin-bottom: 0.75rem; }
  .links-list { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .links-list a { color: var(--accent-primary); font-weight: 500; text-decoration: underline; font-size: 0.95rem; }
  .links-list a:hover { color: #fff; }
  @media (max-width: 768px) { .split-container { grid-template-columns: 1fr; } }
</style>

<script>
  const input = document.getElementById('text-input') as HTMLTextAreaElement;
  const output = document.getElementById('base64-output') as HTMLTextAreaElement;
  const btnEncode = document.getElementById('btn-encode');
  const btnClear = document.getElementById('btn-clear');
  const btnCopy = document.getElementById('btn-copy');

  function encode() {
    if (!input || !output) return;
    const val = input.value;
    if (!val) { output.value = ''; return; }
    try {
      const utf8Bytes = new TextEncoder().encode(val);
      let binary = '';
      for (let i = 0; i < utf8Bytes.byteLength; i++) binary += String.fromCharCode(utf8Bytes[i]);
      output.value = btoa(binary);
    } catch (e: any) {
      output.value = 'Error: ' + e.message;
    }
  }

  if (btnEncode) btnEncode.addEventListener('click', encode);
  if (btnClear && input && output) btnClear.addEventListener('click', () => { input.value = ''; output.value = ''; });
  if (btnCopy && output) btnCopy.addEventListener('click', () => {
    if (output.value) navigator.clipboard.writeText(output.value).then(() => { btnCopy.textContent = 'Copied!'; setTimeout(() => { btnCopy.textContent = 'Copy'; }, 2000); });
  });
</script>
