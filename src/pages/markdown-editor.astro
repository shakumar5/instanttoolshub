---
import Layout from '../layouts/Layout.astro';
import SEOContent from '../components/SEOContent.astro';
import RelatedTools from '../components/RelatedTools.astro';

const toolName = "Markdown Editor & README Generator Online — Free, Instant, Private";
const pageHeading = "Markdown Editor & README Generator";
const activeTool = "markdown-editor";
const accentColor = "#a855f7"; // Purple
const accentGlow = "rgba(168, 85, 247, 0.15)";

const seoDescription = "Write Markdown with live preview, generate GitHub README files from templates, insert tables, and export to HTML or .md — all instantly in your browser, no data uploaded.";
const seoKeywords = "markdown editor online, markdown preview, markdown to html, readme generator, github readme template, markdown table generator, markdown export, readme maker free";

const howToUse = [
  "Select a template from the 'README Templates' dropdown to kickstart your project profile, or type your own Markdown.",
  "Use the toolbar to quickly insert bolding, italics, code snippets, lists, or custom table structures.",
  "Type on the left and see the fully parsed preview render on the right in real-time.",
  "Click 'Export HTML' to download the raw HTML source code, or click 'Export MD' to download the standard Markdown file."
];

const faqs = [
  {
    q: "Is this Markdown editor safe and private?",
    a: "Yes. This editor runs entirely in your browser using JavaScript. Your content is never sent to any server — it stays on your device. Files are generated and downloaded locally, making it safe for private documentation, internal READMEs, and sensitive project notes."
  },
  {
    q: "What is Markdown?",
    a: "Markdown is a lightweight markup language that uses plain-text formatting syntax (like # for headings, ** for bold, - for lists) to create structured documents. It is widely used for README files on GitHub, documentation sites, blogs, and technical writing because it is simple to read and write."
  },
  {
    q: "How do the README templates work?",
    a: "Select a template from the dropdown (e.g., 'Developer Profile', 'API Documentation', 'Open Source Project'). The editor loads a pre-structured Markdown document with placeholder content, badges, and sections. Edit the text to match your project, then export as .md and commit it to your repository."
  },
  {
    q: "Can I export to PDF?",
    a: "Yes. Click the 'Print / PDF' button. It opens your browser's print dialog with a clean stylesheet that hides the editor UI, giving you a document-ready print. Choose 'Save as PDF' in the print dialog to download a PDF file."
  },
  {
    q: "What Markdown syntax is supported?",
    a: "The editor supports headings (H1–H6), bold, italic, inline code, fenced code blocks with syntax highlighting, blockquotes, ordered and unordered lists, tables, horizontal rules, images, and hyperlinks. It covers the most common Markdown features used in GitHub-flavoured documents."
  },
  {
    q: "How does the table generator work?",
    a: "Click the table icon in the toolbar, specify the number of columns and rows, then click 'Insert'. The editor generates a properly formatted Markdown table with header row, separator row, and data rows — ready for you to fill in."
  }
];

// WebApplication structured data for this specific tool
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Markdown Editor & README Generator",
  "url": "https://instanttoolshub.com/markdown-editor",
  "description": "Free online Markdown editor with live preview. Generate GitHub README files from templates, insert tables, and export to HTML or .md — all client-side.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "browserRequirements": "Requires JavaScript",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "featureList": [
    "Live Markdown preview with syntax highlighting",
    "README template library (8 templates)",
    "Markdown table generator",
    "Export to HTML with embedded styles",
    "Export to .md file",
    "Toolbar formatting shortcuts",
    "Print/PDF export",
    "Client-side processing — no data uploaded"
  ],
  "isAccessibleForFree": true,
  "provider": {
    "@type": "Organization",
    "name": "InstantToolsHub",
    "url": "https://instanttoolshub.com"
  }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Compose Markdown documents, generate professional GitHub profile READMEs, and download outputs instantly.</p>
  </div>
  <div class="panel glass">
    <div class="panel-header toolbar-header">
      <div class="editor-toolbar">
        <select id="readme-templates" class="form-select toolbar-select">
          <option value="" data-url="/markdown-editor">-- Choose README Template --</option>
          <option value="minimal" data-url="/markdown-editor/minimal-readme">Minimal Project README</option>
          <option value="professional" data-url="/markdown-editor/professional-readme">Professional Project README</option>
          <option value="profile" data-url="/markdown-editor/profile-readme">Developer Profile README</option>
          <option value="api" data-url="/markdown-editor/api-readme">API Documentation README</option>
          <option value="opensource" data-url="/markdown-editor/opensource-readme">Open Source Project README</option>
          <option value="startup" data-url="/markdown-editor/startup-readme">SaaS/Startup README</option>
          <option value="cli" data-url="/markdown-editor/cli-readme">CLI Tool README</option>
          <option value="library" data-url="/markdown-editor/library-readme">Library/Package README</option>
        </select>
        
        <div class="divider"></div>

        <button class="tool-btn" id="btn-bold" title="Bold (Ctrl+B)"><strong>B</strong></button>
        <button class="tool-btn" id="btn-italic" title="Italic (Ctrl+I)"><em>I</em></button>
        <button class="tool-btn" id="btn-heading" title="Heading (H3)">H</button>
        <button class="tool-btn" id="btn-quote" title="Blockquote">&gt;</button>
        <button class="tool-btn" id="btn-code" title="Code Block">&lt;/&gt;</button>
        <button class="tool-btn" id="btn-link" title="Insert Link">🔗</button>
        <button class="tool-btn" id="btn-table" title="Insert Table">|田|</button>
        
        <div class="divider"></div>
        <button class="btn btn-outline btn-xs" id="btn-cheatsheet-toggle">View Cheatsheet</button>
      </div>

      <div class="panel-header-actions">
        <button class="btn btn-secondary btn-xs" id="btn-copy-md">Copy MD</button>
        <button class="btn btn-outline btn-xs" id="btn-print-pdf">Print / PDF</button>
        <button class="btn btn-outline btn-xs" id="btn-download-html">Export HTML</button>
        <button class="btn btn-primary btn-xs" id="btn-download-md">Export MD</button>
      </div>
    </div>
    <div class="panel-body editor-workspace">
      <div class="split-editor-container">
        <div class="editor-side">
          <textarea id="markdown-input" placeholder="# Write your Markdown here...&#10;&#10;Use the toolbar above or choose a README template to get started!" class="markdown-textarea code-font"></textarea>
        </div>
        <div class="preview-side">
          <div class="markdown-body" id="markdown-preview" aria-live="polite">
            <div class="preview-placeholder">Live parsed preview will display here...</div>
          </div>
        </div>
      </div>
      <div class="cheatsheet-overlay hidden" id="cheatsheet-overlay">
        <div class="cheatsheet-box glass">
          <div class="cheatsheet-box-header">
            <h4>Markdown Cheatsheet</h4>
            <button class="btn btn-outline btn-xs" id="btn-cheatsheet-close">Close</button>
          </div>
          <div class="cheatsheet-content">
            <div class="cheat-item"><span># Heading 1</span><p>Title</p></div>
            <div class="cheat-item"><span>## Heading 2</span><p>Section</p></div>
            <div class="cheat-item"><span>**text**</span><p>Bold</p></div>
            <div class="cheat-item"><span>*text*</span><p>Italic</p></div>
            <div class="cheat-item"><span>[Link](url)</span><p>Hyperlink</p></div>
            <div class="cheat-item"><span>![Alt](img-url)</span><p>Image link</p></div>
            <div class="cheat-item"><span>- item</span><p>Unordered list</p></div>
            <div class="cheat-item"><span>1. item</span><p>Ordered list</p></div>
            <div class="cheat-item"><span>`code`</span><p>Inline code</p></div>
            <div class="cheat-item"><span>&gt; quote</span><p>Blockquote</p></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="modal-backdrop hidden" id="table-modal">
    <div class="modal-box glass">
      <h3>Insert Table</h3>
      <div class="form-grid-row">
        <div class="form-control">
          <label class="form-label">Columns</label>
          <input type="number" id="table-cols" value="3" min="1" max="10" class="form-input" />
        </div>
        <div class="form-control">
          <label class="form-label">Rows</label>
          <input type="number" id="table-rows" value="3" min="1" max="10" class="form-input" />
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-primary btn-sm" id="btn-confirm-table">Insert</button>
        <button class="btn btn-outline btn-sm" id="btn-cancel-table">Cancel</button>
      </div>
    </div>
  </div>

  <RelatedTools currentTool="markdown-editor" />

  <SEOContent 
    toolName={pageHeading}
    description="Markdown is the standard plain-text formatting language for developer documentation, GitHub README files, blogs, and technical writing. This free online Markdown editor gives you a split-pane workspace — type Markdown on the left, see it rendered in real time on the right. Choose from 8 pre-built README templates (project docs, developer profiles, API references, CLI tools, and more) to scaffold professional documentation in seconds. Insert formatted tables with the table generator, apply toolbar shortcuts for bold, italic, headings, and code blocks, then export your finished document as clean HTML or a downloadable .md file. Everything runs client-side — your content never leaves your browser."
    howToUse={howToUse}
    faqs={faqs}
  />

  <section class="seo-section">
    <div class="seo-info-card glass">
      <h2>Markdown Editor Features</h2>
      <div class="features-list">
        <div class="feature-item">
          <h3>Live Preview</h3>
          <p>See your Markdown rendered instantly as you type. The split-pane editor shows source on the left and formatted output on the right with no delay.</p>
        </div>
        <div class="feature-item">
          <h3>README Template Library</h3>
          <p>8 professional README templates for projects, developer profiles, APIs, CLI tools, open-source repos, startups, and libraries. Select, customize, and export in seconds.</p>
        </div>
        <div class="feature-item">
          <h3>Table Generator</h3>
          <p>Specify rows and columns, click Insert, and get a properly formatted Markdown table with header separators ready to fill in — no manual pipe-alignment needed.</p>
        </div>
        <div class="feature-item">
          <h3>Export to HTML</h3>
          <p>Download a standalone HTML file with embedded styles. Use it for documentation hosting, email content, or static site pages.</p>
        </div>
        <div class="feature-item">
          <h3>Syntax Highlighting</h3>
          <p>Fenced code blocks support language-specific syntax highlighting for JavaScript, TypeScript, Python, Bash, HTML, CSS, and JSON.</p>
        </div>
        <div class="feature-item">
          <h3>100% Private</h3>
          <p>No data is sent to any server. All parsing, rendering, and file generation happens in your browser. Safe for internal documentation and private project notes.</p>
        </div>
      </div>
    </div>

    <div class="seo-info-card glass">
      <h2>Related Developer Tools</h2>
      <p>Building documentation or working on code? These tools on InstantToolsHub complement the Markdown editor:</p>
      <ul class="related-links-list">
        <li><a href="/code-minifier-beautifier"><strong>Code Minifier &amp; Beautifier</strong></a> — Minify or format HTML, CSS, and JavaScript assets alongside your docs</li>
        <li><a href="/json-formatter"><strong>JSON Formatter &amp; Validator</strong></a> — Format and validate JSON config files referenced in your README</li>
        <li><a href="/regex-tester"><strong>Regex Tester</strong></a> — Test and debug regular expressions documented in your project</li>
        <li><a href="/hash-generator"><strong>Hash &amp; HMAC Generator</strong></a> — Generate checksums for file integrity verification in release notes</li>
      </ul>
    </div>
  </section>
</Layout>

<style>
  .tool-header {
    margin-bottom: 1.5rem;
  }
  .tool-header h1 {
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .panel {
    display: flex;
    flex-direction: column;
    min-height: 520px;
    height: 640px;
    overflow: hidden;
  }

  .toolbar-header {
    padding: 0.5rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(15, 23, 42, 0.4);
    border-bottom: 1px solid var(--border-light);
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .editor-toolbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .toolbar-select {
    width: 220px;
    padding: 0.35rem 0.5rem;
    font-size: 0.8rem;
    background-color: var(--bg-primary);
  }

  .divider {
    width: 1px;
    height: 20px;
    background: var(--border-light);
    margin: 0 0.25rem;
  }

  .tool-btn {
    background: transparent;
    border: 1px solid transparent;
    color: var(--text-secondary);
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    transition: all var(--transition-fast);
  }

  .tool-btn:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--border-light);
  }

  .panel-body {
    flex-grow: 1;
    position: relative;
    overflow: hidden;
  }

  .split-editor-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100%;
    background: #030712;
  }

  .editor-side {
    border-right: 1px solid var(--border-light);
    height: 100%;
  }

  .markdown-textarea {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    padding: 1.25rem;
    color: var(--text-primary);
    resize: none;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .preview-side {
    height: 100%;
    overflow-y: auto;
    padding: 1.25rem;
    background: #090e16;
  }

  /* HTML Markdown Preview Styles */
  .markdown-body {
    color: #cbd5e1;
    font-size: 0.95rem;
    line-height: 1.625;
  }

  :global(.markdown-body h1, .markdown-body h2, .markdown-body h3) {
    color: #fff;
    margin-top: 1rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  :global(.markdown-body h1) { font-size: 1.8rem; border-bottom: 1px solid var(--border-light); padding-bottom: 0.35rem; }
  :global(.markdown-body h2) { font-size: 1.4rem; border-bottom: 1px solid var(--border-light); padding-bottom: 0.25rem; }
  :global(.markdown-body h3) { font-size: 1.15rem; }
  
  :global(.markdown-body p) { margin-bottom: 1rem; color: #cbd5e1; }
  :global(.markdown-body code) { font-family: var(--font-mono); background: rgba(255, 255, 255, 0.08); padding: 0.15rem 0.35rem; border-radius: 4px; color: #a78bfa; font-size: 0.85rem; }
  :global(.markdown-body pre) { background: #000; padding: 1rem; border-radius: var(--radius-sm); border: 1px solid var(--border-light); overflow-x: auto; margin-bottom: 1rem; }
  :global(.markdown-body pre code) { color: #f3f4f6; background: transparent; padding: 0; }
  
  :global(.markdown-body ul, .markdown-body ol) { margin-left: 1.5rem; margin-bottom: 1rem; }
  :global(.markdown-body li) { margin-bottom: 0.25rem; }

  :global(.markdown-body blockquote) { border-left: 4px solid var(--accent-primary); padding-left: 1rem; color: var(--text-secondary); margin-bottom: 1rem; font-style: italic; }

  :global(.markdown-body table) { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
  :global(.markdown-body th, .markdown-body td) { border: 1px solid var(--border-light); padding: 0.5rem 0.75rem; font-size: 0.85rem; }
  :global(.markdown-body th) { background: rgba(255, 255, 255, 0.03); font-weight: 600; color: #fff; }

  :global(.markdown-body hr) { border: none; border-top: 1px solid var(--border-light); margin: 1.5rem 0; }

  :global(.markdown-body img) { max-width: 100%; border-radius: var(--radius-sm); margin: 0.5rem 0; }

  .preview-placeholder {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-align: center;
    padding: 4rem;
  }

  /* Cheatsheet overlay box */
  .cheatsheet-overlay {
    position: absolute;
    top: 0;
    right: 0;
    width: 250px;
    height: 100%;
    z-index: 10;
    background: rgba(11, 15, 25, 0.9);
    border-left: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
  }

  .cheatsheet-box {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1rem;
  }

  .cheatsheet-box-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 0.5rem;
  }

  .cheatsheet-box-header h4 {
    color: #fff;
  }

  .cheatsheet-content {
    flex-grow: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cheat-item {
    font-size: 0.775rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .cheat-item span {
    font-family: var(--font-mono);
    color: #a855f7; /* purple */
  }

  .cheat-item p {
    color: var(--text-secondary);
  }

  /* Table Modal Styles */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
  }

  .modal-box {
    width: 320px;
    padding: 1.5rem;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .modal-box h3 {
    color: #fff;
  }

  .form-grid-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  /* Hide print headers when printed */
  @media print {
    body * {
      visibility: hidden;
    }
    #markdown-preview, #markdown-preview * {
      visibility: visible;
    }
    #markdown-preview {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      background: white !important;
      color: black !important;
    }
    :global(.markdown-body h1, .markdown-body h2, .markdown-body h3) {
      color: black !important;
    }
    :global(.markdown-body p) {
      color: #333 !important;
    }
  }

  .hidden {
    display: none !important;
  }

  @media (max-width: 850px) {
    .split-editor-container {
      grid-template-columns: 1fr;
      overflow-y: auto;
    }
    .editor-side {
      border-right: none;
      border-bottom: 1px solid var(--border-light);
      height: 250px;
    }
    .features-list {
      grid-template-columns: 1fr;
    }
  }

  /* Features list */
  .features-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .feature-item h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
  }

  .feature-item p {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Related links list */
  .related-links-list {
    list-style: none;
    padding: 0;
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-links-list li {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .related-links-list a {
    color: var(--accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .related-links-list a:hover {
    color: #fff;
  }
</style>

<script>
  // Elements
  const mdInput = document.getElementById('markdown-input') as HTMLTextAreaElement | null;
  const mdPreview = document.getElementById('markdown-preview');
  const templatesSelect = document.getElementById('readme-templates') as HTMLSelectElement | null;

  // Toolbar
  const btnBold = document.getElementById('btn-bold');
  const btnItalic = document.getElementById('btn-italic');
  const btnHeading = document.getElementById('btn-heading');
  const btnQuote = document.getElementById('btn-quote');
  const btnCode = document.getElementById('btn-code');
  const btnLink = document.getElementById('btn-link');
  const btnTable = document.getElementById('btn-table');

  // Cheatsheet
  const cheatsheetToggle = document.getElementById('btn-cheatsheet-toggle');
  const cheatsheetClose = document.getElementById('btn-cheatsheet-close');
  const cheatsheetOverlay = document.getElementById('cheatsheet-overlay');

  // Modal Table
  const tableModal = document.getElementById('table-modal');
  const tableCols = document.getElementById('table-cols') as HTMLInputElement | null;
  const tableRows = document.getElementById('table-rows') as HTMLInputElement | null;
  const btnConfirmTable = document.getElementById('btn-confirm-table');
  const btnCancelTable = document.getElementById('btn-cancel-table');

  // Export buttons
  const btnCopyMd = document.getElementById('btn-copy-md');
  const btnPrintPdf = document.getElementById('btn-print-pdf');
  const btnDownloadHtml = document.getElementById('btn-download-html');
  const btnDownloadMd = document.getElementById('btn-download-md');

  // Pre-configured Templates
  const templates = {
