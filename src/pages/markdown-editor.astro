  /**
   * Export the rendered Markdown content as a complete HTML document.
   * Generates and triggers download of "exported-markdown.html" containing
   * DOCTYPE, html, head with style block, and body with rendered Markdown.
   * If input is empty, still generates a valid HTML file with empty body content.
   */
  function exportHtml(): void {
    if (!mdInput) return;
    const renderedContent = compileMarkdown(mdInput.value);
    const htmlText = `<!DOCTYPE html>
<html lang="en">
<head>
