  // Setup template loading
  if (templatesSelect && mdInput) {
    templatesSelect.addEventListener('change', () => {
      const selected = templatesSelect.value;
      if (selected && templates[selected as keyof typeof templates]) {
        mdInput.value = templates[selected as keyof typeof templates];
        triggerPreview();
      }
    });
  }

  // Live Preview Hook
  if (mdInput) {
    mdInput.addEventListener('input', triggerPreview);
  }

  function triggerPreview() {
    if (!mdInput || !mdPreview) return;
    const text = mdInput.value;
    
    if (!text.trim()) {
      mdPreview.innerHTML = '<div class="preview-placeholder">Live parsed preview will display here...</div>';
      return;
    }

    mdPreview.innerHTML = compileMarkdown(text);
  }

  // --- COPY TO CLIPBOARD ---
  if (btnCopyMd && mdInput) {
    btnCopyMd.addEventListener('click', () => {
      navigator.clipboard.writeText(mdInput.value).then(() => {
        btnCopyMd.textContent = 'Copied!';
        setTimeout(() => { btnCopyMd.textContent = 'Copy MD'; }, 2000);
      });
    });
  }

  // --- HTML / PDF / MD EXPORTS ---
  if (btnPrintPdf) {
    btnPrintPdf.addEventListener('click', () => {
      window.print();
    });
  }

  /**
   * Export the rendered Markdown content as a complete HTML document.
   * Generates and triggers download of "exported-markdown.html" containing
   * DOCTYPE, html, head with style block, and body with rendered Markdown.
   * If input is empty, still generates a valid HTML file with empty body content.
   */
  function exportHtml(): void {
    if (!mdInput) return;
    const renderedContent = compileMarkdown(mdInput.value);
    const htmlText = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Exported Markdown</title>
  <style>
    body { font-family: sans-serif; line-height: 1.6; padding: 2rem; max-width: 800px; margin: 0 auto; color: #333; }
    pre { background: #f4f4f4; padding: 1rem; border-radius: 4px; overflow-x: auto; }
    code { font-family: monospace; background: #f4f4f4; padding: 0.2rem 0.4rem; border-radius: 4px; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
    th, td { border: 1px solid #ccc; padding: 0.5rem 0.75rem; text-align: left; }
    th { background: #eee; }
    blockquote { border-left: 4px solid #8b5cf6; padding-left: 1rem; color: #666; font-style: italic; margin-left: 0; }
  </style>
</head>
<body>
  ${renderedContent}
</body>
</html>`;
    downloadFile(htmlText, 'exported-markdown.html', 'text/html');
  }

  /**
   * Export the raw Markdown text as a .md file.
   * Triggers download of "README.md" containing the raw Markdown from the input panel.
   * If input is empty, still generates and downloads an empty .md file.
   */
  function exportMd(): void {
    if (!mdInput) return;
    downloadFile(mdInput.value, 'README.md', 'text/markdown');
  }

  if (btnDownloadHtml) {
    btnDownloadHtml.addEventListener('click', exportHtml);
  }

  if (btnDownloadMd) {
    btnDownloadMd.addEventListener('click', exportMd);
  }

  function downloadFile(content: string, filename: string, contentType: string) {
    const blob = new Blob([content], { type: contentType });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
  }

  // --- CHEATSHEET ---
  if (cheatsheetToggle && cheatsheetOverlay) {
    cheatsheetToggle.addEventListener('click', () => {
      cheatsheetOverlay.classList.remove('hidden');
    });
  }
  if (cheatsheetClose && cheatsheetOverlay) {
    cheatsheetClose.addEventListener('click', () => {
      cheatsheetOverlay.classList.add('hidden');
    });
  }

  // --- TOOLBAR SHORTCUTS ---
  function insertFormat(prefix: string, suffix = "") {
    if (!mdInput) return;
    const start = mdInput.selectionStart;
    const end = mdInput.selectionEnd;
    const text = mdInput.value;
    const selectedText = text.substring(start, end);
    
    const replacement = prefix + selectedText + suffix;
    mdInput.value = text.substring(0, start) + replacement + text.substring(end);
    
    // Maintain cursor position
    mdInput.focus();
    mdInput.selectionStart = start + prefix.length;
    mdInput.selectionEnd = start + prefix.length + selectedText.length;
    
    triggerPreview();
  }

  if (btnBold) btnBold.addEventListener('click', () => insertFormat("**", "**"));
  if (btnItalic) btnItalic.addEventListener('click', () => insertFormat("*", "*"));
  if (btnHeading) btnHeading.addEventListener('click', () => insertFormat("### "));
  if (btnQuote) btnQuote.addEventListener('click', () => insertFormat("> "));
  if (btnCode) btnCode.addEventListener('click', () => insertFormat("```\n", "\n```"));
  if (btnLink) btnLink.addEventListener('click', () => insertFormat("[", "](https://example.com)"));

  // Table Generator Modal triggers
  if (btnTable && tableModal) {
    btnTable.addEventListener('click', () => {
      tableModal.classList.remove('hidden');
    });
  }
  if (btnCancelTable && tableModal) {
    btnCancelTable.addEventListener('click', () => {
      tableModal.classList.add('hidden');
    });
  }
  if (btnConfirmTable && tableModal && tableCols && tableRows && mdInput) {
    btnConfirmTable.addEventListener('click', () => {
      const cols = Math.max(1, Math.min(10, parseInt(tableCols.value, 10) || 3));
      const rows = Math.max(1, Math.min(10, parseInt(tableRows.value, 10) || 3));

      const table = generateTable(rows, cols);
      insertFormat(table);
      tableModal.classList.add('hidden');
    });
  }

  /**
   * Generate a formatted Markdown table string.
   * @param rows Number of data rows (1–10)
   * @param cols Number of columns (1–10)
   * @returns Markdown table string with header row, separator row, and data rows
   */
  function generateTable(rows: number, cols: number): string {
    let tableMd = "\n";
    // Header row with placeholder text
    tableMd += "| " + Array(cols).fill("Header").join(" | ") + " |\n";
    // Separator row with dashes and pipes
    tableMd += "| " + Array(cols).fill("---").join(" | ") + " |\n";
    // Data rows with placeholder text
    for (let r = 0; r < rows; r++) {
      tableMd += "| " + Array(cols).fill("Cell").join(" | ") + " |\n";
    }
    return tableMd;
  }

  // --- CUSTOM LINE-BY-LINE MARKDOWN PARSER (Client-Side) ---
  function compileMarkdown(md: string): string {
    const lines = md.split('\n');
    let html = "";
    
    let inUnorderedList = false;
    let inOrderedList = false;
    let inBlockquote = false;
    let inCodeBlock = false;
    let codeContent = "";
    let codeLang = "";
    let inTable = false;

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i].trim();

      // Code blocks checker
      if (line.startsWith('```')) {
        if (inCodeBlock) {
          inCodeBlock = false;
          html += `<pre><code class="language-${codeLang}">${highlightSyntax(codeContent.trimEnd(), codeLang)}</code></pre>`;
          codeContent = "";
          codeLang = "";
        } else {
          inCodeBlock = true;
          codeLang = line.slice(3).trim() || "text";
        }
        continue;
      }

      if (inCodeBlock) {
        codeContent += lines[i] + '\n';
        continue;
      }

      // Close open elements if line is empty
      if (line === "") {
        if (inUnorderedList) { html += '</ul>'; inUnorderedList = false; }
        if (inOrderedList) { html += '</ol>'; inOrderedList = false; }
        if (inBlockquote) { html += '</blockquote>'; inBlockquote = false; }
        if (inTable) { html += '</tbody></table>'; inTable = false; }
        continue;
      }

      // Horizontal rules (---, ***, ___)
      if (/^([-*_])\1{2,}$/.test(line)) {
        if (inUnorderedList) { html += '</ul>'; inUnorderedList = false; }
        if (inOrderedList) { html += '</ol>'; inOrderedList = false; }
        html += '<hr>';
        continue;
      }

      // Headers
      if (line.startsWith('#')) {
        const hashCount = line.match(/^#+/)?.[0].length || 1;
        const text = line.replace(/^#+\s*/, '');
        const tag = `h${Math.min(6, hashCount)}`;
        html += `<${tag}>${parseInline(text)}</${tag}>`;
        continue;
      }

      // Blockquotes
      if (line.startsWith('>')) {
        if (!inBlockquote) {
          inBlockquote = true;
          html += '<blockquote>';
        }
        html += `<p>${parseInline(line.replace(/^>\s*/, ''))}</p>`;
        continue;
      }

      // Unordered lists
      if (line.startsWith('- ') || line.startsWith('* ')) {
        if (inOrderedList) { html += '</ol>'; inOrderedList = false; }
        if (!inUnorderedList) {
          inUnorderedList = true;
          html += '<ul>';
        }
        html += `<li>${parseInline(line.substring(2))}</li>`;
        continue;
      }

      // Ordered lists (numbered)
      if (/^\d+\.\s/.test(line)) {
        if (inUnorderedList) { html += '</ul>'; inUnorderedList = false; }
        if (!inOrderedList) {
          inOrderedList = true;
          html += '<ol>';
        }
        const text = line.replace(/^\d+\.\s*/, '');
        html += `<li>${parseInline(text)}</li>`;
        continue;
      }

      // Table Parser
      if (line.startsWith('|') && line.endsWith('|')) {
        const cells = line.split('|').map(c => c.trim()).filter((_c, idx, arr) => idx > 0 && idx < arr.length - 1);
        
        if (!inTable) {
          inTable = true;
          html += '<table><thead><tr>';
          cells.forEach(cell => {
            html += `<th>${parseInline(cell)}</th>`;
          });
          html += '</tr></thead><tbody>';
          continue;
        }

        // Skip divider lines e.g. |---|---|
        if (cells.every(cell => /^[-:]+$/.test(cell))) {
          continue;
        }

        // Render standard row
        html += '<tr>';
        cells.forEach(cell => {
          html += `<td>${parseInline(cell)}</td>`;
        });
        html += '</tr>';
        continue;
      }

      // Standard Paragraph
      html += `<p>${parseInline(line)}</p>`;
    }

    // Close any unclosed tags at EOF
    if (inUnorderedList) html += '</ul>';
    if (inOrderedList) html += '</ol>';
    if (inBlockquote) html += '</blockquote>';
    if (inTable) html += '</tbody></table>';

    return html;
  }

  function parseInline(text: string): string {
    let html = escapeHtml(text);

    // Images
    html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" />');

    // Hyperlinks
    html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');

    // Code inline
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

    // Bold
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/__([^_]+)__/g, '<strong>$1</strong>');

    // Italic
    html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');
    html = html.replace(/_([^_]+)_/g, '<em>$1</em>');

    return html;
  }

  function escapeHtml(text: string) {
    return text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  // Syntax highlighting for code blocks
  function highlightSyntax(code: string, lang: string): string {
    const escaped = escapeHtml(code);
    
    const jsKeywords = /\b(const|let|var|function|return|if|else|for|while|do|switch|case|break|continue|new|this|class|extends|import|export|from|default|async|await|try|catch|finally|throw|typeof|instanceof|in|of|yield|delete|void|null|undefined|true|false)\b/g;
    const pyKeywords = /\b(def|class|import|from|return|if|elif|else|for|while|try|except|finally|raise|with|as|pass|break|continue|yield|lambda|and|or|not|in|is|True|False|None|self|print)\b/g;
    const htmlTags = /(&lt;\/?)([\w-]+)/g;
    const htmlAttrs = /\b([a-zA-Z-]+)(=)/g;
    const strings = /(&quot;[^&]*?&quot;|&#039;[^&]*?&#039;|`[^`]*?`)/g;
    const comments = /(\/\/[^\n]*|\/\*[\s\S]*?\*\/|#[^\n]*)/g;
    const numbers = /\b(\d+\.?\d*)\b/g;
    const cssProps = /([a-z-]+)(\s*:)/g;

    let result = escaped;

    if (lang === 'javascript' || lang === 'js' || lang === 'typescript' || lang === 'ts') {
      result = result
        .replace(comments, '<span style="color:#6b7280;font-style:italic;">$1</span>')
        .replace(strings, '<span style="color:#a5d6ff;">$1</span>')
        .replace(jsKeywords, '<span style="color:#ff7b72;">$1</span>')
        .replace(numbers, '<span style="color:#79c0ff;">$1</span>');
    } else if (lang === 'python' || lang === 'py') {
      result = result
        .replace(comments, '<span style="color:#6b7280;font-style:italic;">$1</span>')
        .replace(strings, '<span style="color:#a5d6ff;">$1</span>')
        .replace(pyKeywords, '<span style="color:#ff7b72;">$1</span>')
        .replace(numbers, '<span style="color:#79c0ff;">$1</span>');
    } else if (lang === 'html' || lang === 'xml') {
      result = result
        .replace(htmlTags, '$1<span style="color:#7ee787;">$2</span>')
        .replace(strings, '<span style="color:#a5d6ff;">$1</span>');
    } else if (lang === 'css') {
      result = result
        .replace(comments, '<span style="color:#6b7280;font-style:italic;">$1</span>')
        .replace(cssProps, '<span style="color:#79c0ff;">$1</span>$2')
        .replace(strings, '<span style="color:#a5d6ff;">$1</span>')
        .replace(numbers, '<span style="color:#ffa657;">$1</span>');
    } else if (lang === 'bash' || lang === 'sh' || lang === 'shell') {
      result = result
        .replace(comments, '<span style="color:#6b7280;font-style:italic;">$1</span>')
        .replace(strings, '<span style="color:#a5d6ff;">$1</span>')
        .replace(/\b(sudo|apt|npm|yarn|git|cd|ls|mkdir|rm|cp|mv|echo|cat|grep|chmod|chown|curl|wget)\b/g, '<span style="color:#ff7b72;">$1</span>');
    } else if (lang === 'json') {
      result = result
        .replace(/(&quot;[^&]*?&quot;)(\s*:)/g, '<span style="color:#79c0ff;">$1</span>$2')
        .replace(/:\s*(&quot;[^&]*?&quot;)/g, ': <span style="color:#a5d6ff;">$1</span>')
        .replace(/:\s*(\d+\.?\d*)/g, ': <span style="color:#ffa657;">$1</span>')
        .replace(/\b(true|false|null)\b/g, '<span style="color:#ff7b72;">$1</span>');
    } else {
      // Generic: highlight strings and numbers
      result = result
        .replace(strings, '<span style="color:#a5d6ff;">$1</span>')
        .replace(numbers, '<span style="color:#79c0ff;">$1</span>');
    }

    return result;
  }
