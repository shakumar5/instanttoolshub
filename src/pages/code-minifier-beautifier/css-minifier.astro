---
import Layout from '../../layouts/Layout.astro';
import SEOContent from '../../components/SEOContent.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const toolName = "CSS Minifier Online — Free, Instant, Private";
const pageHeading = "CSS Minifier";
const activeTool = "code-minifier-beautifier";
const accentColor = "#ec4899";
const accentGlow = "rgba(236, 72, 153, 0.15)";

const seoDescription = "Minify CSS by removing comments, whitespace, and formatting. Reduce CSS file size for faster page loads and better Core Web Vitals — 100% free, client-side, no data uploaded.";
const seoKeywords = "css minifier, minify css online, css compressor, compress css, css minification, reduce css size, css minifier free, optimize css";

const howToUse = [
  "Paste your CSS code into the input editor.",
  "Click 'Minify' to remove all comments, whitespace, and unnecessary characters.",
  "View the compression statistics showing original vs minified file size.",
  "Click 'Copy' to copy the minified CSS for production use.",
  "The minified output is ready to deploy — paste into your stylesheets or build pipeline."
];

const faqs = [
  {
    q: "What does CSS minification remove?",
    a: "CSS minification strips all comments (/* ... */), extra whitespace, line breaks, last semicolons in declaration blocks, and unnecessary spaces around selectors and properties. The resulting CSS is functionally identical but much smaller."
  },
  {
    q: "Does minifying CSS break anything?",
    a: "No. CSS minification only removes cosmetic characters. Selectors, properties, values, and specificity are preserved exactly. The minified CSS renders identically in all browsers."
  },
  {
    q: "How much smaller will my CSS get?",
    a: "Typical compression is 20-40% for well-formatted CSS. Heavily commented CSS with verbose formatting can see 50%+ reduction. The tool shows exact byte savings."
  },
  {
    q: "Is this safe for production use?",
    a: "Yes. All processing runs in your browser. Your CSS code never leaves your device. The output is production-ready."
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "CSS Minifier",
  "url": "https://instanttoolshub.com/code-minifier-beautifier/css-minifier",
  "description": "Free online CSS minifier. Compress CSS files instantly in your browser for faster page loads.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "isAccessibleForFree": true,
  "provider": { "@type": "Organization", "name": "InstantToolsHub", "url": "https://instanttoolshub.com" }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Compress CSS by removing comments, whitespace, and formatting for production-ready stylesheets.</p>
  </div>

  <div class="panel glass">
    <div class="panel-header">
      <span>CSS Minifier</span>
      <div class="panel-header-actions">
        <button class="btn btn-outline btn-xs" id="btn-clear">Clear</button>
        <button class="btn btn-primary btn-xs" id="btn-minify">Minify</button>
        <button class="btn btn-primary btn-xs copy-btn" id="btn-copy">Copy</button>
      </div>
    </div>
    <div class="panel-body">
      <div class="split-container">
        <div class="split-pane">
          <div class="split-label">CSS Input</div>
          <textarea id="css-input" placeholder="Paste your CSS here..." class="form-textarea code-textarea"></textarea>
        </div>
        <div class="split-pane">
          <div class="split-label">Minified Output</div>
          <textarea id="css-output" readonly placeholder="Minified CSS will appear here..." class="form-textarea code-textarea output"></textarea>
        </div>
      </div>
      <div id="stats-bar" class="stats-bar hidden"></div>
    </div>
  </div>

  <div class="sub-tools-nav glass">
    <h3>More Code Tools</h3>
    <div class="links-list">
      <a href="/code-minifier-beautifier">All Languages</a>
      <a href="/code-minifier-beautifier/css-beautifier">CSS Beautifier</a>
      <a href="/code-minifier-beautifier/javascript-minifier">JavaScript Minifier</a>
      <a href="/code-minifier-beautifier/html-minifier">HTML Minifier</a>
    </div>
  </div>

  <RelatedTools currentTool="code-minifier-beautifier" />

  <SEOContent 
    toolName={pageHeading}
    description="CSS minification is a critical page speed optimization. Every kilobyte of CSS must be downloaded and parsed before the browser can render visible content — CSS is render-blocking by default. Minification removes comments, collapses whitespace, strips redundant semicolons, and eliminates unnecessary spacing without changing how the stylesheet is interpreted. Combined with gzip compression, minified CSS typically achieves 80-90% total size reduction compared to development source files."
    howToUse={howToUse}
    faqs={faqs}
  />
</Layout>

<style>
  .tool-header { margin-bottom: 1.5rem; }
  .tool-header h1 { color: #fff; margin-bottom: 0.5rem; }
  .panel { display: flex; flex-direction: column; min-height: 450px; height: 550px; overflow: hidden; }
  .panel-header { padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.4); font-weight: 600; font-size: 0.95rem; }
  .panel-header-actions { display: flex; gap: 0.5rem; }
  .panel-body { flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; }
  .split-container { display: grid; grid-template-columns: 1fr 1fr; flex-grow: 1; }
  .split-pane { display: flex; flex-direction: column; border-right: 1px solid var(--border-light); }
  .split-pane:last-child { border-right: none; }
  .split-label { padding: 0.5rem 1.25rem; background: rgba(15, 23, 42, 0.5); border-bottom: 1px solid var(--border-light); font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
  .code-textarea { width: 100%; height: 100%; flex-grow: 1; border: none; padding: 1.25rem; font-family: var(--font-mono); font-size: 0.85rem; background: #030712; color: #e2e8f0; resize: none; outline: none; }
  .code-textarea.output { color: #f472b6; }
  .stats-bar { padding: 0.6rem 1.25rem; background: rgba(236, 72, 153, 0.1); border-top: 1px solid rgba(236, 72, 153, 0.2); font-size: 0.8rem; color: #f472b6; font-family: var(--font-mono); }
  .hidden { display: none !important; }
  .sub-tools-nav { padding: 1.5rem; margin-top: 2rem; }
  .sub-tools-nav h3 { color: #fff; font-size: 1.15rem; margin-bottom: 0.75rem; }
  .links-list { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .links-list a { color: var(--accent-primary); font-weight: 500; text-decoration: underline; font-size: 0.95rem; }
  .links-list a:hover { color: #fff; }
  @media (max-width: 768px) { .split-container { grid-template-columns: 1fr; } }
</style>

<script>
  const input = document.getElementById('css-input') as HTMLTextAreaElement;
  const output = document.getElementById('css-output') as HTMLTextAreaElement;
  const statsBar = document.getElementById('stats-bar');
  const btnMinify = document.getElementById('btn-minify');
  const btnClear = document.getElementById('btn-clear');
  const btnCopy = document.getElementById('btn-copy');

  function minifyCSS(css: string): string {
    let result = css;
    result = result.replace(/\/\*[\s\S]*?\*\//g, ''); // Remove comments
    result = result.replace(/\s+/g, ' '); // Collapse whitespace
    result = result.replace(/\s*([{}:;,>~+])\s*/g, '$1'); // Remove space around symbols
    result = result.replace(/;}/g, '}'); // Remove last semicolon
    result = result.trim();
    return result;
  }

  function minify() {
    if (!input || !output || !statsBar) return;
    const val = input.value;
    if (!val.trim()) { output.value = ''; statsBar.className = 'stats-bar hidden'; return; }
    const minified = minifyCSS(val);
    output.value = minified;
    const orig = new Blob([val]).size;
    const min = new Blob([minified]).size;
    const saved = ((1 - min / orig) * 100).toFixed(1);
    statsBar.textContent = `Original: ${orig} bytes → Minified: ${min} bytes (${saved}% reduction)`;
    statsBar.className = 'stats-bar';
  }

  if (btnMinify) btnMinify.addEventListener('click', minify);
  if (btnClear && input && output && statsBar) btnClear.addEventListener('click', () => { input.value = ''; output.value = ''; statsBar.className = 'stats-bar hidden'; });
  if (btnCopy && output) btnCopy.addEventListener('click', () => {
    if (output.value) navigator.clipboard.writeText(output.value).then(() => { btnCopy.textContent = 'Copied!'; setTimeout(() => { btnCopy.textContent = 'Copy'; }, 2000); });
  });
</script>
