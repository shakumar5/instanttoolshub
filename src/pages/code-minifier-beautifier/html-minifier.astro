---
import Layout from '../../layouts/Layout.astro';
import SEOContent from '../../components/SEOContent.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const toolName = "HTML Minifier Online — Free, Instant, Private";
const pageHeading = "HTML Minifier";
const activeTool = "code-minifier-beautifier";
const accentColor = "#ec4899";
const accentGlow = "rgba(236, 72, 153, 0.15)";

const seoDescription = "Minify HTML by removing comments, whitespace between tags, and unnecessary attributes. Reduce HTML document size for faster page delivery — 100% free, client-side.";
const seoKeywords = "html minifier, minify html online, html compressor, compress html, html minification, reduce html size, html optimizer, minify html free";

const howToUse = [
  "Paste your HTML code into the input editor.",
  "Click 'Minify' to strip comments, collapse whitespace between tags, and remove unnecessary spaces.",
  "View size reduction stats showing bytes saved.",
  "Click 'Copy' to copy the minified HTML.",
  "The output preserves all tags, attributes, and content structure — only cosmetic characters are removed."
];

const faqs = [
  {
    q: "What does HTML minification remove?",
    a: "HTML minification removes comments (<!-- ... -->), collapses multiple whitespace characters between tags to a single space, and strips unnecessary whitespace around attributes. Tag structure and content are fully preserved."
  },
  {
    q: "Does HTML minification affect rendering?",
    a: "No. Browsers collapse whitespace during rendering, so removing it from the source has no visual effect. The page renders identically with fewer bytes transferred."
  },
  {
    q: "How much smaller will my HTML get?",
    a: "Typical reduction is 10-30% depending on comment density and formatting style. Heavily commented HTML with verbose indentation sees the most improvement."
  },
  {
    q: "Is this safe for my HTML templates?",
    a: "Yes. All processing runs in your browser — nothing is uploaded. Tag structure, attributes, and script/style content are fully preserved."
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "HTML Minifier",
  "url": "https://instanttoolshub.com/code-minifier-beautifier/html-minifier",
  "description": "Free online HTML minifier. Compress HTML documents instantly in your browser.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "isAccessibleForFree": true,
  "provider": { "@type": "Organization", "name": "InstantToolsHub", "url": "https://instanttoolshub.com" }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Compress HTML by removing comments and unnecessary whitespace for faster page delivery.</p>
  </div>

  <div class="panel glass">
    <div class="panel-header">
      <span>HTML Minifier</span>
      <div class="panel-header-actions">
        <button class="btn btn-outline btn-xs" id="btn-clear">Clear</button>
        <button class="btn btn-primary btn-xs" id="btn-minify">Minify</button>
        <button class="btn btn-primary btn-xs copy-btn" id="btn-copy">Copy</button>
      </div>
    </div>
    <div class="panel-body">
      <div class="split-container">
        <div class="split-pane">
          <div class="split-label">HTML Input</div>
          <textarea id="html-input" placeholder="Paste your HTML here..." class="form-textarea code-textarea"></textarea>
        </div>
        <div class="split-pane">
          <div class="split-label">Minified Output</div>
          <textarea id="html-output" readonly placeholder="Minified HTML will appear here..." class="form-textarea code-textarea output"></textarea>
        </div>
      </div>
      <div id="stats-bar" class="stats-bar hidden"></div>
    </div>
  </div>

  <div class="sub-tools-nav glass">
    <h3>More Code Tools</h3>
    <div class="links-list">
      <a href="/code-minifier-beautifier">All Languages</a>
      <a href="/code-minifier-beautifier/css-minifier">CSS Minifier</a>
      <a href="/code-minifier-beautifier/css-beautifier">CSS Beautifier</a>
      <a href="/code-minifier-beautifier/javascript-minifier">JavaScript Minifier</a>
    </div>
  </div>

  <RelatedTools currentTool="code-minifier-beautifier" />

  <SEOContent 
    toolName={pageHeading}
    description="HTML is the first resource the browser receives and parses. While typically smaller than CSS and JavaScript, HTML document size directly affects Time to First Byte (TTFB) and First Contentful Paint (FCP). Minification removes HTML comments, collapses whitespace between tags, and strips unnecessary formatting. Combined with server-side compression (gzip/brotli), this can reduce document transfer size by 60-80% compared to the development source."
    howToUse={howToUse}
    faqs={faqs}
  />
</Layout>

<style>
  .tool-header { margin-bottom: 1.5rem; }
  .tool-header h1 { color: #fff; margin-bottom: 0.5rem; }
  .panel { display: flex; flex-direction: column; min-height: 450px; height: 550px; overflow: hidden; }
  .panel-header { padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.4); font-weight: 600; font-size: 0.95rem; }
  .panel-header-actions { display: flex; gap: 0.5rem; }
  .panel-body { flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; }
  .split-container { display: grid; grid-template-columns: 1fr 1fr; flex-grow: 1; }
  .split-pane { display: flex; flex-direction: column; border-right: 1px solid var(--border-light); }
  .split-pane:last-child { border-right: none; }
  .split-label { padding: 0.5rem 1.25rem; background: rgba(15, 23, 42, 0.5); border-bottom: 1px solid var(--border-light); font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
  .code-textarea { width: 100%; height: 100%; flex-grow: 1; border: none; padding: 1.25rem; font-family: var(--font-mono); font-size: 0.85rem; background: #030712; color: #e2e8f0; resize: none; outline: none; }
  .code-textarea.output { color: #f472b6; }
  .stats-bar { padding: 0.6rem 1.25rem; background: rgba(236, 72, 153, 0.1); border-top: 1px solid rgba(236, 72, 153, 0.2); font-size: 0.8rem; color: #f472b6; font-family: var(--font-mono); }
  .hidden { display: none !important; }
  .sub-tools-nav { padding: 1.5rem; margin-top: 2rem; }
  .sub-tools-nav h3 { color: #fff; font-size: 1.15rem; margin-bottom: 0.75rem; }
  .links-list { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .links-list a { color: var(--accent-primary); font-weight: 500; text-decoration: underline; font-size: 0.95rem; }
  .links-list a:hover { color: #fff; }
  @media (max-width: 768px) { .split-container { grid-template-columns: 1fr; } }
</style>

<script>
  const input = document.getElementById('html-input') as HTMLTextAreaElement;
  const output = document.getElementById('html-output') as HTMLTextAreaElement;
  const statsBar = document.getElementById('stats-bar');
  const btnMinify = document.getElementById('btn-minify');
  const btnClear = document.getElementById('btn-clear');
  const btnCopy = document.getElementById('btn-copy');

  function minifyHTML(html: string): string {
    let result = html;
    result = result.replace(/<!--[\s\S]*?-->/g, ''); // Remove comments
    result = result.replace(/>\s+</g, '><'); // Remove whitespace between tags
    result = result.replace(/\s{2,}/g, ' '); // Collapse multiple spaces
    result = result.trim();
    return result;
  }

  function minify() {
    if (!input || !output || !statsBar) return;
    const val = input.value;
    if (!val.trim()) { output.value = ''; statsBar.className = 'stats-bar hidden'; return; }
    const minified = minifyHTML(val);
    output.value = minified;
    const orig = new Blob([val]).size;
    const min = new Blob([minified]).size;
    const saved = ((1 - min / orig) * 100).toFixed(1);
    statsBar.textContent = `Original: ${orig} bytes → Minified: ${min} bytes (${saved}% reduction)`;
    statsBar.className = 'stats-bar';
  }

  if (btnMinify) btnMinify.addEventListener('click', minify);
  if (btnClear && input && output && statsBar) btnClear.addEventListener('click', () => { input.value = ''; output.value = ''; statsBar.className = 'stats-bar hidden'; });
  if (btnCopy && output) btnCopy.addEventListener('click', () => {
    if (output.value) navigator.clipboard.writeText(output.value).then(() => { btnCopy.textContent = 'Copied!'; setTimeout(() => { btnCopy.textContent = 'Copy'; }, 2000); });
  });
</script>
