---
import Layout from '../layouts/Layout.astro';
import SEOContent from '../components/SEOContent.astro';
import RelatedTools from '../components/RelatedTools.astro';

const toolName = "JSON Formatter & Validator Online — Free, Instant, Private";
const pageHeading = "JSON Formatter & Validator";
const activeTool = "json-formatter";
const accentColor = "#10b981"; // Emerald
const accentGlow = "rgba(16, 185, 129, 0.15)";

const seoDescription = "Format, validate, minify, and convert JSON instantly in your browser. No data is ever uploaded to a server. 100% free, client-side JSON formatter with syntax highlighting and error detection.";
const seoKeywords = "json formatter, json validator online, format json online, json pretty print, minify json, json formatter free, json beautifier, json to csv";

const howToUse = [
  "Paste or type your JSON into the input field on the left. The formatter validates your JSON instantly as you type, highlighting any errors in red with a description of what went wrong and which line to check.",
  "Click 'Format JSON' to pretty-print it with 2-space indentation, or 'Minify JSON' to compress it into a single line.",
  "For URL-encoded JSON strings, click 'URL Decode & Format' to extract and format in one step.",
  "Inspect your formatted structure dynamically in the 'Tree View' tab.",
  "Convert JSON data to comma-separated values in the 'JSON to CSV' tab.",
  "Use the 'JSON Diff' tab to compare your original raw JSON with your modified version side-by-side.",
  "Use the 'Copy' button to copy the output directly to your clipboard. Your JSON data never leaves your browser — processing happens entirely client-side with no server requests."
];

const faqs = [
  {
    q: "Is this JSON formatter safe to use with sensitive data?",
    a: "Yes. This JSON formatter runs entirely in your browser using JavaScript. Your data is never sent to any server — it never leaves your device. This makes it safe to use with API keys, credentials, internal config files, and any other sensitive JSON data."
  },
  {
    q: "What is JSON formatting?",
    a: "JSON formatting (also called pretty-printing) adds consistent indentation, line breaks, and whitespace to a JSON string so it's easy for humans to read. Unformatted JSON is often a single long line with no whitespace — formatting structures it into a readable hierarchy."
  },
  {
    q: "What is the difference between JSON formatting and JSON validation?",
    a: "Formatting changes how JSON looks (adding spaces and indentation) but doesn't check if it's correct. Validation checks whether your JSON follows the JSON specification — catching missing commas, unmatched brackets, trailing commas, and incorrect quote types. This tool does both."
  },
  {
    q: "What does JSON minification do?",
    a: "JSON minification removes all whitespace, indentation, and line breaks from a JSON string to make it as small as possible. This is useful before sending JSON in API responses or embedding it in source code, as it reduces payload size."
  },
  {
    q: "Can I format JSON in JavaScript without a tool?",
    a: "Yes. In JavaScript, you can format JSON using <code>JSON.stringify(data, null, 2)</code> — the third argument sets the indentation level. To validate, wrap <code>JSON.parse()</code> in a try/catch block. This online tool automates both operations instantly without writing any code."
  },
  {
    q: "Why is my JSON invalid?",
    a: "Common JSON errors include: trailing commas after the last item in an array or object (not allowed in JSON, unlike JavaScript), single quotes instead of double quotes around strings, missing quotes around object keys, unescaped special characters in strings, and comments (JSON does not support comments). This validator highlights exactly where the error is."
  }
];

// WebApplication structured data for this specific tool
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "JSON Formatter & Validator",
  "url": "https://instanttoolshub.com/json-formatter",
  "description": "Free online JSON formatter and validator. Format, minify, validate, and convert JSON data instantly in your browser with no data uploads.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "browserRequirements": "Requires JavaScript",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "featureList": [
    "JSON formatting and pretty-print",
    "JSON validation with error highlighting",
    "JSON minification",
    "JSON to CSV conversion",
    "Interactive tree view",
    "JSON diff comparison",
    "Client-side processing — no data uploaded",
    "Syntax highlighting",
    "Copy to clipboard"
  ],
  "isAccessibleForFree": true,
  "provider": {
    "@type": "Organization",
    "name": "InstantToolsHub",
    "url": "https://instanttoolshub.com"
  }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Format, validate, minify, and convert JSON data instantly — 100% client-side, nothing leaves your browser.</p>
  </div>

  <div class="tool-grid">
    <div class="panel glass">
      <div class="panel-header">
        <span>Input JSON</span>
        <div class="panel-header-actions">
          <button class="btn btn-outline btn-xs" id="clear-input">Clear</button>
          <button class="btn btn-outline btn-xs" id="sample-json">Sample</button>
        </div>
      </div>
      <div class="panel-body">
        <textarea id="json-input" placeholder="Paste your raw JSON or URL-encoded JSON here..." class="form-textarea json-textarea"></textarea>
        <div id="validation-alert" class="validation-alert hidden"></div>
      </div>
    </div>
    <div class="panel glass">
      <div class="panel-header tabbed-header">
        <div class="tabs">
          <button class="tab-btn active" data-tab="tab-formatted">Beautified</button>
          <button class="tab-btn" data-tab="tab-tree">Tree View</button>
          <button class="tab-btn" data-tab="tab-diff">JSON Diff</button>
          <button class="tab-btn" data-tab="tab-csv">JSON to CSV</button>
        </div>
        <div class="panel-header-actions">
          <button class="btn btn-primary btn-xs copy-btn" id="copy-output">Copy</button>
        </div>
      </div>
      
      <div class="panel-body tab-content-container">
        <div class="tab-content active" id="tab-formatted">
          <div class="code-container">
            <div class="code-header">
              <span id="output-meta">Formatted JSON</span>
            </div>
            <textarea id="json-output" readonly placeholder="Formatted output will appear here..." class="code-editor json-textarea" aria-live="polite"></textarea>
          </div>
        </div>
        <div class="tab-content" id="tab-tree">
          <div class="tree-container" id="tree-view-output" aria-live="polite">
            <div class="placeholder-text">Tree view will render here after entering valid JSON.</div>
          </div>
        </div>
        <div class="tab-content" id="tab-diff">
          <div class="diff-container">
            <div class="diff-panel">
              <div class="diff-label">Original (Input)</div>
              <div id="diff-original" class="diff-viewer"></div>
            </div>
            <div class="diff-panel">
              <div class="diff-label">Formatted (Output)</div>
              <div id="diff-formatted" class="diff-viewer"></div>
            </div>
          </div>
        </div>
        <div class="tab-content" id="tab-csv">
          <div class="code-container">
            <div class="code-header">CSV Raw Output</div>
            <textarea id="csv-output" readonly placeholder="CSV conversion will appear here..." class="code-editor json-textarea" style="color: #60a5fa;" aria-live="polite"></textarea>
          </div>
        </div>
      </div>
    </div>
    <div class="tool-actions">
      <div class="action-group">
        <label class="form-label" style="margin-right: 0.5rem; display: inline-block;">Indentation:</label>
        <select id="json-indent" class="form-select inline-select">
          <option value="2">2 Spaces</option>
          <option value="4">4 Spaces</option>
          <option value="tab">1 Tab</option>
        </select>
      </div>
      
      <div class="action-buttons">
        <button class="btn btn-primary" id="btn-format">Format JSON</button>
        <button class="btn btn-secondary" id="btn-minify">Minify JSON</button>
        <button class="btn btn-outline" id="btn-url-decode" title="Decodes percent encoding first, then formats">URL Decode & Format</button>
      </div>
    </div>
  </div>

  <div class="sub-tools-grid glass">
    <h3>Dedicated JSON Tools</h3>
    <p>Use these focused tools for specific JSON operations:</p>
    <div class="links-list">
      <a href="/json-formatter/validator">JSON Validator</a>
      <a href="/json-formatter/minifier">JSON Minifier</a>
      <a href="/json-formatter/json-to-csv">JSON to CSV Converter</a>
      <a href="/json-formatter/tree-viewer">JSON Tree Viewer</a>
      <a href="/json-formatter/json-diff">JSON Diff Checker</a>
    </div>
  </div>

  <RelatedTools currentTool="json-formatter" />

  <SEOContent 
    toolName={pageHeading}
    description="JSON (JavaScript Object Notation) is a lightweight text format for exchanging data between systems. In its raw form, JSON is often a dense, single-line string with no whitespace — readable by machines, but difficult for humans to scan and debug. JSON formatting, also called pretty-printing, restructures that raw string by adding consistent indentation and line breaks. A deeply nested API response that would otherwise be unreadable becomes a clear hierarchy you can inspect at a glance."
    howToUse={howToUse}
    faqs={faqs}
  />

  <section class="seo-section">
    <div class="seo-info-card glass">
      <h2>JSON Formatter Features</h2>
      <div class="features-list">
        <div class="feature-item">
          <h3>Format & Pretty-Print</h3>
          <p>Restructures any valid JSON with 2-space indentation and sorted line breaks. Works on JSON of any size, from single objects to deeply nested API payloads.</p>
        </div>
        <div class="feature-item">
          <h3>Validate with Error Detection</h3>
          <p>Catches the most common JSON mistakes: trailing commas, single-quoted strings, unquoted keys, missing brackets, and unexpected characters. The error message tells you exactly which line to fix.</p>
        </div>
        <div class="feature-item">
          <h3>Minify</h3>
          <p>Strips all whitespace and newlines to produce the most compact version of your JSON. Use this before including JSON in API responses, environment configs, or source code.</p>
        </div>
        <div class="feature-item">
          <h3>Convert to CSV</h3>
          <p>Convert JSON to CSV format for use in spreadsheets. Nested keys are flattened (e.g., "address.city") for easy tabular representation.</p>
        </div>
        <div class="feature-item">
          <h3>Syntax Highlighting</h3>
          <p>Keys, strings, numbers, booleans, and null values are colour-coded for fast visual scanning of your JSON structure.</p>
        </div>
        <div class="feature-item">
          <h3>100% Private</h3>
          <p>No data is sent to any server. Everything runs in your browser. Safe for API keys, auth tokens, internal configs, and any other sensitive data.</p>
        </div>
      </div>
    </div>

    <div class="seo-info-card glass">
      <h2>Common JSON Errors and How to Fix Them</h2>
      <div class="errors-guide">
        <div class="error-item">
          <h3>Trailing Comma</h3>
          <p>The most common JSON error. JSON, unlike JavaScript, does not allow a comma after the last item in an array or object.</p>
          <pre><code set:html={`// ❌ Invalid\n{"name": "Priya", "role": "admin",}\n\n// ✅ Valid\n{"name": "Priya", "role": "admin"}`} /></pre>
        </div>
        <div class="error-item">
          <h3>Single Quotes Instead of Double Quotes</h3>
          <p>JSON requires double quotes for all strings and keys. Single quotes are valid in JavaScript but not in JSON.</p>
          <pre><code set:html={`// ❌ Invalid\n{'name': 'Priya'}\n\n// ✅ Valid\n{"name": "Priya"}`} /></pre>
        </div>
        <div class="error-item">
          <h3>Unquoted Keys</h3>
          <p>All JSON object keys must be wrapped in double quotes, even if they look like valid identifiers.</p>
          <pre><code set:html={`// ❌ Invalid\n{name: "Priya"}\n\n// ✅ Valid\n{"name": "Priya"}`} /></pre>
        </div>
        <div class="error-item">
          <h3>Comments in JSON</h3>
          <p>JSON does not support comments. If you need annotated JSON, consider JSON5 or YAML instead.</p>
        </div>
        <div class="error-item">
          <h3>Unescaped Special Characters</h3>
          <p>Backslashes, double quotes, and control characters inside string values must be escaped with a backslash.</p>
          <pre><code set:html={`// ❌ Invalid\n{"path": "C:\\Users\\Priya\\Documents"}\n\n// ✅ Valid\n{"path": "C:\\\\Users\\\\Priya\\\\Documents"}`} /></pre>
        </div>
      </div>
    </div>

    <div class="seo-info-card glass">
      <h2>Related Developer Tools</h2>
      <p>Working with JSON? These tools on InstantToolsHub pair well with the formatter:</p>
      <ul class="related-links-list">
        <li><a href="/jwt-decoder"><strong>JWT Decoder & Debugger</strong></a> — Decode the JSON payload inside a JWT token</li>
        <li><a href="/base64"><strong>Base64 Encoder & Decoder</strong></a> — Decode Base64-encoded JSON strings before formatting</li>
        <li><a href="/hash-generator"><strong>Hash & HMAC Generator</strong></a> — Generate checksums to verify JSON payload integrity</li>
        <li><a href="/url-encoder-decoder"><strong>URL Encoder & Decoder</strong></a> — Decode URL-encoded JSON from query strings</li>
      </ul>
    </div>
  </section>
</Layout>

<style>
  .tool-header {
    margin-bottom: 1.5rem;
  }
  .tool-header h1 {
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .panel {
    display: flex;
    flex-direction: column;
    min-height: 500px;
    height: 600px;
    overflow: hidden;
  }

  .panel-header {
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(15, 23, 42, 0.4);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .tabbed-header {
    padding: 0;
    padding-right: 1rem;
  }

  .tabs {
    display: flex;
    height: 100%;
  }

  .tab-btn {
    background: transparent;
    border: none;
    border-right: 1px solid var(--border-light);
    color: var(--text-secondary);
    padding: 0.75rem 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .tab-btn:hover {
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-primary);
  }

  .tab-btn.active {
    background: var(--bg-primary);
    color: var(--accent-primary);
    border-bottom: 2px solid var(--accent-primary);
  }

  .panel-header-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-xs {
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
  }

  .panel-body {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .tab-content-container {
    height: calc(100% - 45px);
  }

  .json-textarea {
    width: 100%;
    height: 100%;
    flex-grow: 1;
    border: none;
    border-radius: 0;
    padding: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    background: transparent;
    color: #a7f3d0;
  }

  textarea#json-input {
    color: #e2e8f0;
    background: #030712;
  }

  .validation-alert {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.85rem 1.25rem;
    font-size: 0.85rem;
    border-top: 1px solid var(--border-light);
    z-index: 10;
  }

  .validation-alert.success {
    background: rgba(16, 185, 129, 0.15);
    color: #34d399;
    border-top-color: rgba(16, 185, 129, 0.3);
  }

  .validation-alert.error {
    background: rgba(239, 68, 68, 0.15);
    color: #f87171;
    border-top-color: rgba(239, 68, 68, 0.3);
    font-family: var(--font-mono);
    white-space: pre-wrap;
  }

  .hidden {
    display: none !important;
  }

  /* Tabs content */
  .tab-content {
    display: none;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .tab-content.active {
    display: block;
  }

  .tab-content .code-container {
    height: 100%;
    border: none;
  }

  /* Tree View */
  .tree-container {
    padding: 1.5rem;
    height: 100%;
    overflow-y: auto;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: #04060a;
  }

  .placeholder-text {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-align: center;
    padding: 3rem;
  }

  /* Diff Checker */
  .diff-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100%;
    background: #04060a;
    overflow: hidden;
  }

  .diff-panel {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-right: 1px solid var(--border-light);
  }

  .diff-panel:last-child {
    border-right: none;
  }

  .diff-label {
    padding: 0.5rem 1rem;
    background: rgba(15, 23, 42, 0.5);
    border-bottom: 1px solid var(--border-light);
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .diff-viewer {
    flex-grow: 1;
    overflow: auto;
    padding: 1rem;
    white-space: pre;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  /* Actions Layout */
  .inline-select {
    width: 130px;
    padding: 0.4rem 0.75rem;
    font-size: 0.85rem;
    display: inline-block;
  }

  .action-buttons {
    display: flex;
    gap: 0.75rem;
  }

  /* Styling for Tree elements */
  :global(.tree-ul) {
    list-style: none;
    padding-left: 1.5rem;
    border-left: 1px dashed rgba(255, 255, 255, 0.08);
  }
  :global(.tree-li) {
    margin: 0.2rem 0;
    position: relative;
  }
  :global(.tree-expander) {
    cursor: pointer;
    color: var(--text-muted);
    user-select: none;
    margin-right: 0.25rem;
    display: inline-block;
    transition: transform var(--transition-fast);
  }
  :global(.tree-expander.collapsed) {
    transform: rotate(-90deg);
  }
  :global(.tree-key) {
    color: #818cf8; /* indigo */
    font-weight: 500;
  }
  :global(.tree-string) {
    color: #34d399; /* emerald */
  }
  :global(.tree-number) {
    color: #fb923c; /* orange */
  }
  :global(.tree-boolean) {
    color: #38bdf8; /* sky */
  }
  :global(.tree-null) {
    color: #f87171; /* red */
  }

  /* Features list */
  .features-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .feature-item h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
  }

  .feature-item p {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Errors guide */
  .errors-guide {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .error-item h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
  }

  .error-item p {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .error-item pre {
    background: #000;
    padding: 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-light);
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .error-item code {
    font-family: var(--font-mono);
    color: #e2e8f0;
  }

  /* Related links list */
  .related-links-list {
    list-style: none;
    padding: 0;
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-links-list li {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .related-links-list a {
    color: var(--accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .related-links-list a:hover {
    color: #fff;
  }

  @media (max-width: 768px) {
    .features-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Elements
  const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement | null;
  const jsonOutput = document.getElementById('json-output') as HTMLTextAreaElement | null;
  const csvOutput = document.getElementById('csv-output') as HTMLTextAreaElement | null;
  const treeOutput = document.getElementById('tree-view-output');
  const diffOriginal = document.getElementById('diff-original');
  const diffFormatted = document.getElementById('diff-formatted');
  const validationAlert = document.getElementById('validation-alert');
  const indentSelect = document.getElementById('json-indent') as HTMLSelectElement | null;

  // Buttons
  const btnFormat = document.getElementById('btn-format');
  const btnMinify = document.getElementById('btn-minify');
  const btnUrlDecode = document.getElementById('btn-url-decode');
  const btnSample = document.getElementById('sample-json');
  const btnClear = document.getElementById('clear-input');
  const btnCopy = document.getElementById('copy-output');

  // Sample JSON data
  const sampleData = {
    "site": "InstantToolsHub",
    "version": 1.0,
    "active": true,
    "features": [
      "JSON Formatter",
      "Base64 Tool",
      "JWT Decoder"
    ],
    "owner": {
      "name": "Admin",
      "email": "contact@instanttoolshub.com"
    },
    "traffic_stats": null
  };

  // Setup tabs
  const tabs = document.querySelectorAll('.tab-btn');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      const targetTabId = tab.getAttribute('data-tab');
      const tabContents = document.querySelectorAll('.tab-content');
      tabContents.forEach(content => {
        content.classList.remove('active');
        if (content.id === targetTabId) {
          content.classList.add('active');
        }
      });
    });
  });

  // Sample data loader
  if (btnSample && jsonInput) {
    btnSample.addEventListener('click', () => {
      jsonInput.value = JSON.stringify(sampleData, null, 2);
      processJSON('format');
    });
  }

  // Clear input
  if (btnClear && jsonInput && jsonOutput && csvOutput && treeOutput && diffOriginal && diffFormatted && validationAlert) {
    btnClear.addEventListener('click', () => {
      jsonInput.value = "";
      jsonOutput.value = "";
      csvOutput.value = "";
      treeOutput.innerHTML = '<div class="placeholder-text">Tree view will render here after entering valid JSON.</div>';
      diffOriginal.innerHTML = "";
      diffFormatted.innerHTML = "";
      validationAlert.className = "validation-alert hidden";
    });
  }

  // Copy output
  if (btnCopy && jsonOutput) {
    btnCopy.addEventListener('click', () => {
      // Find active tab and copy its content
      const activeTabBtn = document.querySelector('.tab-btn.active');
      const activeTabId = activeTabBtn ? activeTabBtn.getAttribute('data-tab') : '';
      let textToCopy = '';

      if (activeTabId === 'tab-formatted') {
        textToCopy = jsonOutput.value;
      } else if (activeTabId === 'tab-csv' && csvOutput) {
        textToCopy = csvOutput.value;
      } else if (activeTabId === 'tab-tree' && treeOutput) {
        textToCopy = JSON.stringify(JSON.parse(jsonInput?.value || '{}'), null, 2);
      } else {
        textToCopy = jsonOutput.value;
      }

      if (textToCopy) {
        navigator.clipboard.writeText(textToCopy).then(() => {
          btnCopy.classList.add('copied');
          btnCopy.textContent = 'Copied!';
          setTimeout(() => {
            btnCopy.classList.remove('copied');
            btnCopy.textContent = 'Copy';
          }, 2000);
        });
      }
    });
  }

  // Formatter actions
  if (btnFormat) btnFormat.addEventListener('click', () => processJSON('format'));
  if (btnMinify) btnMinify.addEventListener('click', () => processJSON('minify'));
  if (btnUrlDecode) {
    btnUrlDecode.addEventListener('click', () => {
      if (jsonInput && jsonInput.value) {
        try {
          const decoded = decodeURIComponent(jsonInput.value);
          jsonInput.value = decoded;
          processJSON('format');
        } catch (e: any) {
          showError("URL Decode failed: " + e.message);
        }
      }
    });
  }

  function getIndent() {
    if (!indentSelect) return 2;
    const val = indentSelect.value;
    if (val === 'tab') return '\t';
    return parseInt(val, 10);
  }

  function showError(msg: string) {
    if (validationAlert && jsonOutput) {
      validationAlert.textContent = msg;
      validationAlert.className = "validation-alert error";
      jsonOutput.value = "";
    }
  }

  function showSuccess() {
    if (validationAlert) {
      validationAlert.textContent = "✓ Valid JSON";
      validationAlert.className = "validation-alert success";
    }
  }

  function processJSON(mode: 'format' | 'minify') {
    if (!jsonInput || !jsonOutput) return;
    const inputVal = jsonInput.value.trim();

    if (!inputVal) {
      showError("Please enter some JSON to format.");
      return;
    }

    try {
      const parsed = JSON.parse(inputVal);
      showSuccess();

      // Format code
      let outputVal = "";
      if (mode === 'format') {
        outputVal = JSON.stringify(parsed, null, getIndent());
      } else {
        outputVal = JSON.stringify(parsed);
      }
      jsonOutput.value = outputVal;

      // Render Tree View
      renderTreeView(parsed);

      // Render CSV
      renderCSV(parsed);

      // Render Diff View
      renderDiff(inputVal, outputVal);

    } catch (e: any) {
      showError("Invalid JSON: " + e.message);
    }
  }

  // Recursive Tree View Generator
  function renderTreeView(data: any) {
    if (!treeOutput) return;
    treeOutput.innerHTML = '';
    
    const treeRoot = document.createElement('div');
    treeRoot.className = 'tree-root';
    
    if (typeof data !== 'object' || data === null) {
      treeRoot.appendChild(createValueSpan(data));
    } else {
      treeRoot.appendChild(buildTreeNodes(data, ''));
    }
    
    treeOutput.appendChild(treeRoot);
  }

  function buildTreeNodes(data: any, key: string): HTMLElement {
    const isArray = Array.isArray(data);
    const container = document.createElement('div');
    container.className = 'tree-li';

    if (key !== '') {
      const keySpan = document.createElement('span');
      keySpan.className = 'tree-key';
      keySpan.textContent = `"${key}": `;
      container.appendChild(keySpan);
    }

    const startBrace = isArray ? '[' : '{';
    const endBrace = isArray ? ']' : '}';
    const keys = isArray ? data : Object.keys(data);
    
    if (keys.length === 0) {
      const emptySpan = document.createElement('span');
      emptySpan.textContent = `${startBrace}${endBrace}`;
      container.appendChild(emptySpan);
      return container;
    }

    const expander = document.createElement('span');
    expander.className = 'tree-expander';
    expander.textContent = '▼';
    container.insertBefore(expander, container.firstChild);

    const braceSpan = document.createElement('span');
    braceSpan.textContent = startBrace;
    container.appendChild(braceSpan);

    const ul = document.createElement('ul');
    ul.className = 'tree-ul';
    
    if (isArray) {
      data.forEach((val: any, idx: number) => {
        const li = document.createElement('li');
        li.className = 'tree-li';
        if (typeof val === 'object' && val !== null) {
          li.appendChild(buildTreeNodes(val, ''));
        } else {
          li.appendChild(createValueSpan(val));
        }
        ul.appendChild(li);
      });
    } else {
      Object.keys(data).forEach(k => {
        const val = data[k];
        const li = document.createElement('li');
        li.className = 'tree-li';
        if (typeof val === 'object' && val !== null) {
          li.appendChild(buildTreeNodes(val, k));
        } else {
          const keySpan = document.createElement('span');
          keySpan.className = 'tree-key';
          keySpan.textContent = `"${k}": `;
          li.appendChild(keySpan);
          li.appendChild(createValueSpan(val));
        }
        ul.appendChild(li);
      });
    }

    container.appendChild(ul);

    const closeBraceSpan = document.createElement('span');
    closeBraceSpan.textContent = endBrace;
    container.appendChild(closeBraceSpan);

    // Click handler for collapsible lists
    expander.addEventListener('click', (e) => {
      e.stopPropagation();
      ul.classList.toggle('hidden');
      expander.classList.toggle('collapsed');
      if (ul.classList.contains('hidden')) {
        expander.textContent = '▶';
        braceSpan.textContent = `${startBrace}...${endBrace}`;
        closeBraceSpan.style.display = 'none';
      } else {
        expander.textContent = '▼';
        braceSpan.textContent = startBrace;
        closeBraceSpan.style.display = 'inline';
      }
    });

    return container;
  }

  function createValueSpan(val: any): HTMLElement {
    const span = document.createElement('span');
    if (typeof val === 'string') {
      span.className = 'tree-string';
      span.textContent = `"${val}"`;
    } else if (typeof val === 'number') {
      span.className = 'tree-number';
      span.textContent = String(val);
    } else if (typeof val === 'boolean') {
      span.className = 'tree-boolean';
      span.textContent = String(val);
    } else if (val === null) {
      span.className = 'tree-null';
      span.textContent = 'null';
    }
    return span;
  }

  // JSON to CSV flat converter
  function renderCSV(parsed: any) {
    if (!csvOutput) return;
    
    let arr = [];
    if (Array.isArray(parsed)) {
      arr = parsed;
    } else if (typeof parsed === 'object' && parsed !== null) {
      // If single object, put it in array
      arr = [parsed];
    } else {
      csvOutput.value = "Unable to convert: JSON is not an object or array.";
      return;
    }

    try {
      // Flatten all objects in the array
      const flatArray = arr.map((item: any) => flattenObject(item));
      
      // Extract all unique headers
      const headersMap = new Set<string>();
      flatArray.forEach(item => {
        Object.keys(item).forEach(key => headersMap.add(key));
      });
      const headers = Array.from(headersMap);

      if (headers.length === 0) {
        csvOutput.value = "No fields found to output in CSV.";
        return;
      }

      // Construct CSV output
      const csvLines = [];
      csvLines.push(headers.map(h => `"${h.replace(/"/g, '""')}"`).join(','));
      
      flatArray.forEach(item => {
        const line = headers.map(h => {
          const val = item[h];
          if (val === undefined || val === null) return '';
          return `"${String(val).replace(/"/g, '""')}"`;
        }).join(',');
        csvLines.push(line);
      });

      csvOutput.value = csvLines.join('\n');
    } catch (e: any) {
      csvOutput.value = "CSV Conversion error: " + e.message;
    }
  }

  // Helper to flatten nested object
  function flattenObject(ob: any): any {
    const toReturn: any = {};
    for (const i in ob) {
      if (!ob.hasOwnProperty(i)) continue;
      if ((typeof ob[i]) === 'object' && ob[i] !== null) {
        const flatObject = flattenObject(ob[i]);
        for (const x in flatObject) {
          if (!flatObject.hasOwnProperty(x)) continue;
          toReturn[i + '.' + x] = flatObject[x];
        }
      } else {
        toReturn[i] = ob[i];
      }
    }
    return toReturn;
  }

  // Visual diff checker
  function renderDiff(orig: string, form: string) {
    if (!diffOriginal || !diffFormatted) return;
    
    // Simplistic line-by-line diff display
    const origLines = orig.split('\n');
    const formLines = form.split('\n');
    
    let origHtml = "";
    let formHtml = "";

    const maxLines = Math.max(origLines.length, formLines.length);
    for (let i = 0; i < maxLines; i++) {
      const ol = origLines[i] !== undefined ? origLines[i] : "";
      const fl = formLines[i] !== undefined ? formLines[i] : "";

      if (ol !== fl) {
        // Line mismatch
        if (ol !== "") {
          origHtml += `<div class="diff-line diff-del" style="background: rgba(239, 68, 68, 0.15); color: #f87171;">${escapeHtml(ol)}</div>`;
        } else {
          origHtml += `<div class="diff-line">&nbsp;</div>`;
        }

        if (fl !== "") {
          formHtml += `<div class="diff-line diff-add" style="background: rgba(16, 185, 129, 0.15); color: #34d399;">${escapeHtml(fl)}</div>`;
        } else {
          formHtml += `<div class="diff-line">&nbsp;</div>`;
        }
      } else {
        origHtml += `<div class="diff-line">${escapeHtml(ol)}</div>`;
        formHtml += `<div class="diff-line">${escapeHtml(fl)}</div>`;
      }
    }

    diffOriginal.innerHTML = origHtml;
    diffFormatted.innerHTML = formHtml;
  }

  function escapeHtml(text: string) {
    return text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }
</script>
