---
import Layout from '../../layouts/Layout.astro';
import SEOContent from '../../components/SEOContent.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const toolName = "MD5 Hash Generator Online — Free, Instant, Private";
const pageHeading = "MD5 Hash Generator";
const activeTool = "hash-generator";
const accentColor = "#e11d48";
const accentGlow = "rgba(225, 29, 72, 0.15)";

const seoDescription = "Generate MD5 hashes from text instantly in your browser. Compute 128-bit MD5 checksums for strings, verify integrity, and compare hashes — 100% free, no data uploaded.";
const seoKeywords = "md5 hash generator, md5 online, generate md5, md5 checksum, md5 hash calculator, md5 string hash, md5 generator free";

const howToUse = [
  "Type or paste your text into the input field.",
  "The MD5 hash (32 hexadecimal characters) is generated instantly as you type.",
  "Click 'Copy' to copy the hash to your clipboard.",
  "Use the output to verify file integrity, create checksums, or compare data fingerprints."
];

const faqs = [
  {
    q: "What is MD5?",
    a: "MD5 (Message Digest Algorithm 5) is a cryptographic hash function that produces a 128-bit (16-byte) hash value, typically represented as a 32-character hexadecimal string. The same input always produces the same output, but different inputs are extremely unlikely to produce the same hash."
  },
  {
    q: "Is MD5 secure?",
    a: "MD5 is considered cryptographically broken for security purposes — collision attacks exist that can generate different inputs with the same hash. However, MD5 remains useful for non-security purposes like checksums, data deduplication, and cache keys where collision resistance isn't critical."
  },
  {
    q: "What should I use instead of MD5 for security?",
    a: "For security-sensitive applications (password hashing, digital signatures, data integrity), use SHA-256 or SHA-512. For password storage specifically, use bcrypt, scrypt, or Argon2."
  },
  {
    q: "Is this tool safe for sensitive data?",
    a: "Yes. All hashing runs entirely in your browser using the Web Crypto API. No data is sent to any server."
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "MD5 Hash Generator",
  "url": "https://instanttoolshub.com/hash-generator/md5",
  "description": "Free online MD5 hash generator. Compute MD5 checksums from text instantly in your browser.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "isAccessibleForFree": true,
  "provider": { "@type": "Organization", "name": "InstantToolsHub", "url": "https://instanttoolshub.com" }
};
---

<Layout 
  title={toolName} 
  description={seoDescription} 
  keywords={seoKeywords} 
  activeTool={activeTool}
  accentColor={accentColor}
  accentGlow={accentGlow}
>
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(webAppSchema)}<\/script>`} />
  <div class="tool-header">
    <h1>{pageHeading}</h1>
    <p>Compute MD5 hash digests (128-bit, 32 hex chars) from any text input instantly.</p>
  </div>

  <div class="panel glass">
    <div class="panel-header">
      <span>MD5 Hash</span>
      <div class="panel-header-actions">
        <button class="btn btn-outline btn-xs" id="btn-clear">Clear</button>
        <button class="btn btn-primary btn-xs copy-btn" id="btn-copy">Copy Hash</button>
      </div>
    </div>
    <div class="panel-body">
      <div class="input-section">
        <label class="form-label">Input Text</label>
        <textarea id="hash-input" placeholder="Type or paste text to hash..." class="form-textarea code-textarea"></textarea>
      </div>
      <div class="output-section">
        <label class="form-label">MD5 Hash Output</label>
        <input type="text" id="hash-output" readonly placeholder="MD5 hash will appear here..." class="form-input hash-output" />
        <div class="hash-info">128-bit digest | 32 hexadecimal characters</div>
      </div>
    </div>
  </div>

  <div class="sub-tools-nav glass">
    <h3>More Hash Tools</h3>
    <div class="links-list">
      <a href="/hash-generator">All Hash Algorithms</a>
      <a href="/hash-generator/sha256">SHA-256 Generator</a>
      <a href="/hash-generator/sha512">SHA-512 Generator</a>
      <a href="/hash-generator/hmac">HMAC Generator</a>
      <a href="/hash-generator/file-checksum">File Checksum</a>
    </div>
  </div>

  <RelatedTools currentTool="hash-generator" />

  <SEOContent 
    toolName={pageHeading}
    description="MD5 (Message Digest Algorithm 5) processes input data through four rounds of 16 operations each, producing a 128-bit (16-byte) digest represented as 32 hexadecimal characters. Designed by Ronald Rivest in 1991, MD5 was originally used for verifying data integrity and digital signatures. While cryptographic weaknesses (collision attacks) make it unsuitable for security applications, MD5 remains widely used for checksums, cache key generation, data deduplication, and quick file identification where collision resistance isn't required."
    howToUse={howToUse}
    faqs={faqs}
  />
</Layout>

<style>
  .tool-header { margin-bottom: 1.5rem; }
  .tool-header h1 { color: #fff; margin-bottom: 0.5rem; }
  .panel { display: flex; flex-direction: column; overflow: hidden; }
  .panel-header { padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.4); font-weight: 600; font-size: 0.95rem; }
  .panel-header-actions { display: flex; gap: 0.5rem; }
  .panel-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }
  .form-label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
  .code-textarea { width: 100%; min-height: 150px; border: 1px solid var(--border-light); border-radius: var(--radius-sm); padding: 1rem; font-family: var(--font-mono); font-size: 0.9rem; background: #030712; color: #e2e8f0; resize: vertical; outline: none; }
  .code-textarea:focus { border-color: var(--accent-primary); }
  .hash-output { width: 100%; padding: 0.75rem 1rem; font-family: var(--font-mono); font-size: 1rem; background: #030712; border: 1px solid var(--border-light); border-radius: var(--radius-sm); color: #fb7185; outline: none; letter-spacing: 0.025em; }
  .hash-info { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; }
  .sub-tools-nav { padding: 1.5rem; margin-top: 2rem; }
  .sub-tools-nav h3 { color: #fff; font-size: 1.15rem; margin-bottom: 0.75rem; }
  .links-list { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .links-list a { color: var(--accent-primary); font-weight: 500; text-decoration: underline; font-size: 0.95rem; }
  .links-list a:hover { color: #fff; }
</style>

<script>
  const input = document.getElementById('hash-input') as HTMLTextAreaElement;
  const output = document.getElementById('hash-output') as HTMLInputElement;
  const btnCopy = document.getElementById('btn-copy');
  const btnClear = document.getElementById('btn-clear');

  async function computeMD5(text: string): Promise<string> {
    const encoder = new TextEncoder();
    const data = encoder.encode(text);
    const hashBuffer = await crypto.subtle.digest('MD5', data).catch(() => null);
    // MD5 is not supported in Web Crypto in most browsers, use fallback
    if (hashBuffer) {
      return Array.from(new Uint8Array(hashBuffer)).map(b => b.toString(16).padStart(2, '0')).join('');
    }
    // Simple MD5 implementation fallback
    return md5Fallback(text);
  }

  function md5Fallback(str: string): string {
    function md5cycle(x: number[], k: number[]) {
      let a = x[0], b = x[1], c = x[2], d = x[3];
      a = ff(a, b, c, d, k[0], 7, -680876936); d = ff(d, a, b, c, k[1], 12, -389564586); c = ff(c, d, a, b, k[2], 17, 606105819); b = ff(b, c, d, a, k[3], 22, -1044525330);
      a = ff(a, b, c, d, k[4], 7, -176418897); d = ff(d, a, b, c, k[5], 12, 1200080426); c = ff(c, d, a, b, k[6], 17, -1473231341); b = ff(b, c, d, a, k[7], 22, -45705983);
      a = ff(a, b, c, d, k[8], 7, 1770035416); d = ff(d, a, b, c, k[9], 12, -1958414417); c = ff(c, d, a, b, k[10], 17, -42063); b = ff(b, c, d, a, k[11], 22, -1990404162);
      a = ff(a, b, c, d, k[12], 7, 1804603682); d = ff(d, a, b, c, k[13], 12, -40341101); c = ff(c, d, a, b, k[14], 17, -1502002290); b = ff(b, c, d, a, k[15], 22, 1236535329);
      a = gg(a, b, c, d, k[1], 5, -165796510); d = gg(d, a, b, c, k[6], 9, -1069501632); c = gg(c, d, a, b, k[11], 14, 643717713); b = gg(b, c, d, a, k[0], 20, -373897302);
      a = gg(a, b, c, d, k[5], 5, -701558691); d = gg(d, a, b, c, k[10], 9, 38016083); c = gg(c, d, a, b, k[15], 14, -660478335); b = gg(b, c, d, a, k[4], 20, -405537848);
      a = gg(a, b, c, d, k[9], 5, 568446438); d = gg(d, a, b, c, k[14], 9, -1019803690); c = gg(c, d, a, b, k[3], 14, -187363961); b = gg(b, c, d, a, k[8], 20, 1163531501);
      a = gg(a, b, c, d, k[13], 5, -1444681467); d = gg(d, a, b, c, k[2], 9, -51403784); c = gg(c, d, a, b, k[7], 14, 1735328473); b = gg(b, c, d, a, k[12], 20, -1926607734);
      a = hh(a, b, c, d, k[5], 4, -378558); d = hh(d, a, b, c, k[8], 11, -2022574463); c = hh(c, d, a, b, k[11], 16, 1839030562); b = hh(b, c, d, a, k[14], 23, -35309556);
      a = hh(a, b, c, d, k[1], 4, -1530992060); d = hh(d, a, b, c, k[4], 11, 1272893353); c = hh(c, d, a, b, k[7], 16, -155497632); b = hh(b, c, d, a, k[10], 23, -1094730640);
      a = hh(a, b, c, d, k[13], 4, 681279174); d = hh(d, a, b, c, k[0], 11, -358537222); c = hh(c, d, a, b, k[3], 16, -722521979); b = hh(b, c, d, a, k[6], 23, 76029189);
      a = hh(a, b, c, d, k[9], 4, -640364487); d = hh(d, a, b, c, k[12], 11, -421815835); c = hh(c, d, a, b, k[15], 16, 530742520); b = hh(b, c, d, a, k[2], 23, -995338651);
      a = ii(a, b, c, d, k[0], 6, -198630844); d = ii(d, a, b, c, k[7], 10, 1126891415); c = ii(c, d, a, b, k[14], 15, -1416354905); b = ii(b, c, d, a, k[5], 21, -57434055);
      a = ii(a, b, c, d, k[12], 6, 1700485571); d = ii(d, a, b, c, k[3], 10, -1894986606); c = ii(c, d, a, b, k[10], 15, -1051523); b = ii(b, c, d, a, k[1], 21, -2054922799);
      a = ii(a, b, c, d, k[8], 6, 1873313359); d = ii(d, a, b, c, k[15], 10, -30611744); c = ii(c, d, a, b, k[6], 15, -1560198380); b = ii(b, c, d, a, k[13], 21, 1309151649);
      a = ii(a, b, c, d, k[4], 6, -145523070); d = ii(d, a, b, c, k[11], 10, -1120210379); c = ii(c, d, a, b, k[2], 15, 718787259); b = ii(b, c, d, a, k[9], 21, -343485551);
      x[0] = add32(a, x[0]); x[1] = add32(b, x[1]); x[2] = add32(c, x[2]); x[3] = add32(d, x[3]);
    }
    function cmn(q: number, a: number, b: number, x: number, s: number, t: number) { a = add32(add32(a, q), add32(x, t)); return add32((a << s) | (a >>> (32 - s)), b); }
    function ff(a: number, b: number, c: number, d: number, x: number, s: number, t: number) { return cmn((b & c) | ((~b) & d), a, b, x, s, t); }
    function gg(a: number, b: number, c: number, d: number, x: number, s: number, t: number) { return cmn((b & d) | (c & (~d)), a, b, x, s, t); }
    function hh(a: number, b: number, c: number, d: number, x: number, s: number, t: number) { return cmn(b ^ c ^ d, a, b, x, s, t); }
    function ii(a: number, b: number, c: number, d: number, x: number, s: number, t: number) { return cmn(c ^ (b | (~d)), a, b, x, s, t); }
    function add32(a: number, b: number) { return (a + b) & 0xFFFFFFFF; }

    const n = str.length;
    let state = [1732584193, -271733879, -1732584194, 271733878];
    let i: number;
    const bytes = [];
    for (i = 0; i < n; i++) bytes.push(str.charCodeAt(i));
    bytes.push(0x80);
    while (bytes.length % 64 !== 56) bytes.push(0);
    const bitLen = n * 8;
    bytes.push(bitLen & 0xff, (bitLen >> 8) & 0xff, (bitLen >> 16) & 0xff, (bitLen >> 24) & 0xff, 0, 0, 0, 0);
    for (i = 0; i < bytes.length; i += 64) {
      const k: number[] = [];
      for (let j = 0; j < 64; j += 4) k.push(bytes[i+j] | (bytes[i+j+1] << 8) | (bytes[i+j+2] << 16) | (bytes[i+j+3] << 24));
      md5cycle(state, k);
    }
    let hex = '';
    for (i = 0; i < 4; i++) {
      for (let j = 0; j < 4; j++) hex += ((state[i] >> (j * 8)) & 0xff).toString(16).padStart(2, '0');
    }
    return hex;
  }

  async function computeHash() {
    if (!input || !output) return;
    const val = input.value;
    if (!val) { output.value = ''; return; }
    output.value = md5Fallback(val);
  }

  if (input) input.addEventListener('input', computeHash);
  if (btnClear && input && output) btnClear.addEventListener('click', () => { input.value = ''; output.value = ''; });
  if (btnCopy && output) btnCopy.addEventListener('click', () => {
    if (output.value) navigator.clipboard.writeText(output.value).then(() => { btnCopy.textContent = 'Copied!'; setTimeout(() => { btnCopy.textContent = 'Copy Hash'; }, 2000); });
  });
</script>
