---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Page Not Found" 
  description="The page you are looking for doesn't exist. Browse our collection of free developer tools."
>
  <section class="error-section">
    <div class="error-content">
      <div class="error-code">404</div>
      <h1>Page Not Found</h1>
      <p>The tool or page you're looking for doesn't exist or may have moved.</p>
      <div class="error-actions">
        <a href="/" class="btn btn-primary">← Back to All Tools</a>
      </div>
      
      <div class="error-suggestions">
        <h3>Popular Tools</h3>
        <div class="suggestion-links">
          <a href="/json-formatter">JSON Formatter</a>
          <a href="/base64">Base64 Encoder</a>
          <a href="/url-encoder-decoder">URL Encoder</a>
          <a href="/regex-tester">RegEx Tester</a>
          <a href="/jwt-decoder">JWT Decoder</a>
          <a href="/hash-generator">Hash Generator</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .error-section {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
  }

  .error-content {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .error-code {
    font-family: var(--font-heading);
    font-size: 7rem;
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--accent-primary), #f43f5e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .error-content h1 {
    font-size: 1.75rem;
    color: #fff;
  }

  .error-content p {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .error-actions {
    margin-top: 1rem;
  }

  .error-suggestions {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-light);
    width: 100%;
  }

  .error-suggestions h3 {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .suggestion-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .suggestion-links a {
    padding: 0.5rem 1rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .suggestion-links a:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
    background: var(--accent-glow);
  }
</style>
